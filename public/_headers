# Cloudflare Pages headers (this file is ignored by the Render web service).
# When the /public assets are hosted on Cloudflare Pages as a CDN mirror, the
# game runs on a different origin, so the model fetches (GLTFLoader) need CORS.
# The model files never change name, so cache them hard.
/*
  Access-Control-Allow-Origin: *
/kk/*
  Cache-Control: public, max-age=31536000, immutable
/client.js
  Cache-Control: no-cache
