# Copy this file to ".env" (same folder) and fill in the values you want.
# ".env" is gitignored — it's the right place for real secrets. Leave any
# line unset/deleted and that feature just stays disabled; nothing breaks.

# Shared passcode to keep the town private to your friends. Leave unset for
# no password (anyone with the link can join).
TOWN_PASSWORD=

# Stripe secret key — enables Town Pass sales (real payments via Stripe
# Checkout). Get this from the Stripe Dashboard under Developers > API
# keys. Use a sk_test_... key first (test card 4242 4242 4242 4242), then
# swap in your sk_live_... key when you're ready for real money.
# With no key set, the Lounge and Arcade stay locked and the game says
# pass sales aren't set up; everything else works normally.
STRIPE_SECRET_KEY=

# The Town Pass: one purchase opens BOTH ticketed buildings (the Rooftop
# Lounge and the Arcade). Price in cents (99 = $0.99) and duration in
# hours (24 = a day pass). These are the defaults if left unset.
TOWN_PASS_PRICE_CENTS=99
TOWN_PASS_HOURS=24

# Optional Anthropic API key — used only by Witch Hazel's selfie-payment
# shop to double-check that a submitted photo really shows a face. Fails
# open (accepts) if unset.
ANTHROPIC_API_KEY=

# Note: the Arcade's "Text" tab (Twilio SMS) is NOT configured here — each
# player logs into their own Twilio account from inside that tab, and it's
# stored in their own browser, not as server config. See README.
