<Item class="ModuleScript" referent="RBX0024">
<Properties>
<string name="Name">Catalog</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Catalog
	Fish, rods, shop items, emotes, and job definitions. Pure data + lookups.
]]

local Catalog = {}

-- FISH ------------------------------------------------------------------------
-- weight = relative chance. nightOnly/dayOnly restrict when it can bite.
-- rarity drives color + celebration: common / uncommon / rare / epic
Catalog.Fish = {
	{ id = "anchovy",   name = "Anchovy",           rarity = "common",   value = 4,   weight = 30 },
	{ id = "herring",   name = "Silver Herring",    rarity = "common",   value = 6,   weight = 26 },
	{ id = "mackerel",  name = "Bay Mackerel",      rarity = "uncommon", value = 12,  weight = 16 },
	{ id = "flounder",  name = "Flat Flounder",     rarity = "uncommon", value = 15,  weight = 12 },
	{ id = "seabass",   name = "Sea Bass",          rarity = "rare",     value = 28,  weight = 7 },
	{ id = "squid",     name = "Ink Squid",         rarity = "rare",     value = 34,  weight = 6, nightOnly = true },
	{ id = "sunfish",   name = "Golden Sunfish",    rarity = "epic",     value = 80,  weight = 2, dayOnly = true },
	{ id = "lanterneel",name = "Lantern Eel",       rarity = "epic",     value = 95,  weight = 2, nightOnly = true },
	{ id = "moonfish",  name = "Moonfish",          rarity = "epic",     value = 120, weight = 1, nightOnly = true },
	{ id = "boot",      name = "Old Boot",          rarity = "common",   value = 1,   weight = 6 },
	{ id = "bottle",    name = "Message in a Bottle", rarity = "rare",   value = 40,  weight = 2 },
}

Catalog.RarityColors = {
	common = Color3.fromRGB(200, 205, 210),
	uncommon = Color3.fromRGB(120, 200, 140),
	rare = Color3.fromRGB(90, 150, 240),
	epic = Color3.fromRGB(200, 120, 240),
}

-- RODS ---------------------------------------------------------------------------
-- luck multiplies rare/epic weights; speed multiplies bite wait (lower = faster)
Catalog.Rods = {
	{ id = "driftwood", name = "Driftwood Rod", price = 0,    luck = 1.0, speed = 1.0,  color = Color3.fromRGB(150, 120, 90) },
	{ id = "willow",    name = "Willow Rod",    price = 350,  luck = 1.6, speed = 0.85, color = Color3.fromRGB(120, 160, 110) },
	{ id = "starlight", name = "Starlight Rod", price = 1500, luck = 2.6, speed = 0.7,  color = Color3.fromRGB(150, 170, 240) },
}

-- SHOP (General Store + Scoops) ----------------------------------------------------
-- kind: "rod" (equipable), "treat" (consumable visual), "emote" (unlock)
Catalog.ShopItems = {
	{ id = "willow",    kind = "rod",   name = "Willow Rod",      price = 350,  desc = "Luckier and quicker on the line." },
	{ id = "starlight", kind = "rod",   name = "Starlight Rod",   price = 1500, desc = "Night-sky luck. The eels respect it." },
	{ id = "icecream",  kind = "treat", name = "Sea-Salt Swirl",  price = 10,   desc = "Hold a scoop. Instant vacation." },
	{ id = "cocoa",     kind = "treat", name = "Campfire Cocoa",  price = 8,    desc = "Warm hands, warm heart." },
	{ id = "pretzel",   kind = "treat", name = "Boardwalk Pretzel", price = 6,  desc = "Salty, like the air." },
	{ id = "emote_jig",     kind = "emote", name = "Sailor's Jig",   price = 120, desc = "A dance for good hauls." },
	{ id = "emote_cheer2",  kind = "emote", name = "Big Cheer",      price = 80,  desc = "For ferry arrivals." },
	{ id = "emote_twirl",   kind = "emote", name = "Boardwalk Twirl", price = 150, desc = "Golden-hour spins." },
}

-- EMOTES ------------------------------------------------------------------------------
-- Free ones everyone has; purchasable ones unlock via ShopItems (kind = "emote").
-- Animation assets are Roblox-published catalog animations (usable by any game).
Catalog.Emotes = {
	{ id = "wave",   name = "Wave",   animId = "rbxassetid://507770239", free = true },
	{ id = "point",  name = "Point",  animId = "rbxassetid://507770453", free = true },
	{ id = "dance",  name = "Dance",  animId = "rbxassetid://507771019", free = true },
	{ id = "laugh",  name = "Laugh",  animId = "rbxassetid://507770818", free = true },
	{ id = "cheer",  name = "Cheer",  animId = "rbxassetid://507770677", free = true },
	{ id = "emote_jig",    name = "Sailor's Jig",    animId = "rbxassetid://507771955", free = false },
	{ id = "emote_cheer2", name = "Big Cheer",       animId = "rbxassetid://507771406", free = false },
	{ id = "emote_twirl",  name = "Boardwalk Twirl", animId = "rbxassetid://507772104", free = false },
}

-- JOBS ---------------------------------------------------------------------------------
Catalog.JobList = {
	{ id = "barista", name = "Barista", place = "The Bay Cafe", icon = "☕",
	  desc = "Brew orders at the espresso bar and run them to the marked table." },
	{ id = "baker", name = "Baker", place = "Butter &amp; Tide", icon = "🥖",
	  desc = "Knead at the counter, bake in the oven, stock the shelf. Repeat, deliciously." },
	{ id = "courier", name = "Courier", place = "Town Hall", icon = "✉️",
	  desc = "Collect letters at Town Hall and deliver them to cottage mailboxes." },
}

-- LOOKUPS ---------------------------------------------------------------------------------
local function indexBy(list)
	local m = {}
	for _, e in ipairs(list) do m[e.id] = e end
	return m
end

Catalog.FishById = indexBy(Catalog.Fish)
Catalog.RodById = indexBy(Catalog.Rods)
Catalog.ShopById = indexBy(Catalog.ShopItems)
Catalog.EmoteById = indexBy(Catalog.Emotes)
Catalog.JobById = indexBy(Catalog.JobList)

return Catalog
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0025">
<Properties>
<string name="Name">Config</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Config
	Central tuning knobs for the whole game. Everything gameplay-numeric lives here
	so balancing never means hunting through systems code.
]]

local Config = {}

-- ECONOMY ------------------------------------------------------------------
Config.StartingCoins = 100
Config.DataStoreName = "LanternsideBay_v1"
Config.AutosaveIntervalSeconds = 120

-- DAY / NIGHT --------------------------------------------------------------
-- One full in-game day lasts DayLengthMinutes real minutes.
Config.DayLengthMinutes = 16
Config.NightStartHour = 18.5 -- lamps + lighthouse come on
Config.NightEndHour = 6.0    -- lamps off, beam stops

-- FISHING ------------------------------------------------------------------
Config.Fishing = {
	MinCastIntervalSeconds = 1.5,  -- server-side rate limit
	BiteTimeMin = 2.0,             -- seconds until a bite (scaled by rod)
	BiteTimeMax = 6.5,
	ReactionWindowSeconds = 1.6,   -- how long the "!" lasts before the fish escapes
	NightRareBonus = 1.6,          -- multiplier on rare+ weights at night
	MaxFishInventory = 40,
}

-- JOBS ---------------------------------------------------------------------
Config.Jobs = {
	StreakBonusEvery = 5,   -- every N completed tasks...
	StreakBonusCoins = 25,  -- ...pay this on top
	Barista = { PayPerOrder = 12, BrewSeconds = 2.5, OrderTimeoutSeconds = 90 },
	Baker = { PayPerLoaf = 15, KneadSeconds = 3.0, BakeSeconds = 6.0 },
	Courier = { PayPerDelivery = 20, LetterTimeoutSeconds = 180 },
}

-- HOUSING ------------------------------------------------------------------
Config.Housing = {
	MaxCottagesPerPlayer = 1,
	PaintCost = 0, -- repainting is free in v1; make it cost coins later if desired
}

-- INTERACTION --------------------------------------------------------------
Config.MaxInteractDistance = 14 -- studs; server-side proximity validation

-- VISITOR BOT -----------------------------------------------------------------
-- Scout wanders the town playing the game so there's always something to watch.
Config.VisitorBot = { enabled = true, name = "Scout" }

-- CHAT / SOCIAL --------------------------------------------------------------
Config.RoleTitles = { -- curated overhead titles (no free text = no filtering risk)
	"Newcomer", "Local", "Fisher", "Barista", "Baker", "Courier",
	"Artist", "Sailor", "Beachgoer", "Lighthouse Keeper", "Tourist", "Mayor's Aide",
}

-- COTTAGE PAINT PALETTES -----------------------------------------------------
Config.PaintPalettes = {
	{ id = "seafoam",  label = "Seafoam",  wall = Color3.fromRGB(168, 213, 197), trim = Color3.fromRGB(245, 247, 240) },
	{ id = "coral",    label = "Coral",    wall = Color3.fromRGB(233, 150, 122), trim = Color3.fromRGB(250, 240, 222) },
	{ id = "sky",      label = "Sky",      wall = Color3.fromRGB(146, 186, 222), trim = Color3.fromRGB(244, 244, 244) },
	{ id = "butter",   label = "Butter",   wall = Color3.fromRGB(238, 220, 154), trim = Color3.fromRGB(252, 250, 245) },
	{ id = "lavender", label = "Lavender", wall = Color3.fromRGB(186, 168, 210), trim = Color3.fromRGB(246, 243, 250) },
	{ id = "driftwood",label = "Driftwood",wall = Color3.fromRGB(172, 156, 134), trim = Color3.fromRGB(236, 230, 218) },
}

function Config.getPalette(id)
	for _, p in ipairs(Config.PaintPalettes) do
		if p.id == id then return p end
	end
	return Config.PaintPalettes[1]
end

return Config
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0026">
<Properties>
<string name="Name">MapData</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — MapData
	The entire town layout as data. MapBuilder consumes this to generate the world.

	COORDINATE PLAN (studs, Y up):
	  * Origin (0,0) = center of the town square. Ground top sits at Y = 0.
	  * +Z is SOUTH, toward the water. The bay fills everything past z ~ 128.
	  * +X is EAST.
	  * Rough zones:
	      z -190..-60   cottage lanes (two rows of four)
	      z  -60..  60  town square, shop row (north edge), town hall (east), park (west)
	      z   60.. 100  green slope down to the sand
	      z   95.. 130  beach sand + boardwalk (boardwalk deck at y 1.5)
	      z  128..420   the bay (terrain water, surface ~ y -1)
	  * Lighthouse headland: rocky rise around (205, 165), reached by a walkway
	    from the boardwalk's east end.
]]

local MapData = {}

-- WORLD BOUNDS ---------------------------------------------------------------
MapData.Bounds = { xMin = -320, xMax = 320, zMin = -260, zMax = 430 }

-- TERRAIN --------------------------------------------------------------------
-- Filled in order; later fills overwrite earlier ones where they overlap.
MapData.Terrain = {
	-- Base grass slab under the whole land side
	{ material = "Grass", cframe = { 0, -3, -60 }, size = { 640, 6, 400 } },
	-- Beach sand strip (slightly proud of the grass so it reads as a beach)
	{ material = "Sand", cframe = { 0, -2.75, 112 }, size = { 640, 6.5, 44 } },
	-- Sea floor
	{ material = "Sand", cframe = { 0, -13, 280 }, size = { 640, 8, 300 } },
	-- The bay itself (water surface ends up around y -1)
	{ material = "Water", cframe = { 0, -5, 280 }, size = { 640, 8, 300 } },
	-- Rocky headland base for the lighthouse
	{ material = "Rock", cframe = { 205, -1.5, 165 }, size = { 46, 12, 40 } },
}

-- SPAWN ----------------------------------------------------------------------
MapData.Spawn = { x = 0, z = 52, facing = 180 } -- south edge of square, facing the fountain/bay? No: facing 180 looks north into the square.

-- TOWN SQUARE ----------------------------------------------------------------
MapData.Square = {
	center = { 0, 8 },
	size = { 84, 60 },          -- paved plaza
	fountain = { 0, 8 },
	noticeBoard = { 30, -16 },  -- faces the plaza
}

-- PATHS (cobblestone strips laid flat on the grass) ----------------------------
-- Each: { x, z, width, length, rotationDegrees }
-- The plaza-to-lanes route jogs around the shop row: up the shop gaps at
-- x ±26, across behind the shops, then up the central cottage gap at x 0.
MapData.Paths = {
	{ 0, 76, 12, 78, 0 },       -- square down to the boardwalk
	{ -26, -46, 10, 48, 0 },    -- west shop-gap connector
	{ 26, -46, 10, 48, 0 },     -- east shop-gap connector
	{ 0, -78, 10, 62, 90 },     -- cross path behind the shops
	{ 0, -111, 10, 78, 0 },     -- central connector up the cottage gap
	{ 0, -30, 8, 18, 0 },       -- bakery door stub
	{ -56, -30, 8, 18, 0 },     -- cafe door stub
	{ 56, -30, 8, 18, 0 },      -- general store door stub
	{ -74, 8, 10, 64, 90 },     -- square west to the park
	{ 70, 8, 10, 62, 90 },      -- square east to the town hall door
	{ 0, -94, 10, 150, 90 },    -- cottage lane A street (south of the porches)
	{ 0, -150, 10, 150, 90 },   -- cottage lane B street
}

-- SHOP ROW (north side of the square, facing south) ----------------------------
-- Buildings are generated: walls, roof, door opening, windows, sign, interior kit.
MapData.Shops = {
	{
		id = "cafe", name = "The Bay Cafe", kind = "cafe",
		pos = { -56, -52 }, size = { 36, 16, 26 }, facing = 180,
		wall = { 222, 184, 135 }, roof = { 178, 34, 34 }, sign = "THE BAY CAFE",
	},
	{
		id = "bakery", name = "Butter &amp; Tide Bakery", kind = "bakery",
		pos = { 0, -52 }, size = { 34, 15, 26 }, facing = 180,
		wall = { 244, 214, 170 }, roof = { 205, 133, 63 }, sign = "BUTTER &amp; TIDE",
	},
	{
		id = "store", name = "Lanternside General", kind = "store",
		pos = { 56, -52 }, size = { 36, 16, 26 }, facing = 180,
		wall = { 200, 200, 190 }, roof = { 70, 105, 120 }, sign = "GENERAL STORE",
	},
}

-- TOWN HALL --------------------------------------------------------------------
MapData.TownHall = {
	id = "townhall", name = "Town Hall",
	pos = { 118, 8 }, size = { 40, 20, 34 }, facing = 270, -- faces west toward the square
	wall = { 235, 230, 220 }, roof = { 90, 110, 130 }, sign = "TOWN HALL",
}

-- PARK -------------------------------------------------------------------------
MapData.Park = {
	center = { -120, 8 },
	campfire = { -120, 18 },
	benches = { { -132, 6, 90 }, { -108, 6, 270 }, { -120, -6, 0 } }, -- x, z, rotY
	easel = { -104, 24 },
}

-- COTTAGES (claimable) -----------------------------------------------------------
-- Two lanes of four; every cottage faces its street (south).
MapData.Cottages = {}
do
	local laneZ = { -102, -158 }
	local xs = { -96, -34, 34, 96 }
	local names = {
		"Seagrass Cottage", "Tidepool Cottage", "Anchor Cottage", "Pearl Cottage",
		"Driftwood Cottage", "Compass Cottage", "Moonrise Cottage", "Harborlight Cottage",
	}
	local i = 0
	for lane = 1, 2 do
		for k = 1, 4 do
			i = i + 1
			MapData.Cottages[i] = {
				id = "cottage" .. i,
				name = names[i],
				pos = { xs[k], laneZ[lane] - 14 }, -- set back from the street
				size = { 26, 13, 22 },
				facing = 180,
			}
		end
	end
end

-- BOARDWALK / PIER / SEA ----------------------------------------------------------
MapData.Boardwalk = { center = { 0, 112 }, size = { 300, 20 }, deckY = 1.5 }
MapData.Pier = { x = 0, zStart = 122, zEnd = 216, width = 14 }
MapData.FishingSpots = { -- railed positions with a prompt; x, z, facing
	-- pier spots sit ON the deck (pier is 14 wide, x -7..7)
	{ -5, 175, 90 }, { 5, 150, 270 }, { 5, 196, 270 }, { -60, 118, 180 }, { 84, 118, 180 },
}
MapData.MarketStall = { x = -64, z = 106, facing = 180, sign = "FISH MARKET" }   -- sell fish here
MapData.IceCreamStand = { x = 64, z = 106, facing = 180, sign = "SCOOPS" }
MapData.FerryDock = { x = 12, z = 208 }

-- The Pelican's loop around the bay (x, z waypoints; smooth-tweened)
-- Final approach stays south of z 220 so the hull never clips the pier tip.
MapData.FerryRoute = {
	{ 24, 226 }, { 120, 250 }, { 190, 300 }, { 150, 360 }, { 0, 380 },
	{ -150, 355 }, { -210, 295 }, { -140, 245 }, { -10, 232 },
}
MapData.FerrySpeed = 14 -- studs/second along the route

-- LIGHTHOUSE -----------------------------------------------------------------------
MapData.Lighthouse = {
	pos = { 205, 165 }, baseY = 4.5, height = 46, radius = 7,
	walkway = { fromX = 150, toX = 186, z = 105, y = 1.5 }, -- boardwalk east end to headland (then steps)
}

-- STREETLAMPS ------------------------------------------------------------------------
MapData.Lamps = {
	{ -34, 44 }, { 34, 44 }, { -34, -28 }, { 34, -28 },        -- square corners
	{ 0, -88 }, { 0, -140 },                                     -- cottage path
	{ -70, -108 }, { 70, -108 }, { -70, -164 }, { 70, -164 },   -- lanes
	{ -74, 22 }, { 62, 22 },                                     -- park + hall paths
	{ -110, 118 }, { 110, 118 }, { 0, 126 },                     -- boardwalk
	{ 6, 200 },                                                  -- pier end
}

-- TREES / ROCKS / FLOWERS (kind, x, z, scale) -------------------------------------------
MapData.Nature = {}
do
	local pines = {
		{ -150, -40 }, { -160, 40 }, { -96, 52 }, { -144, -16, 1.2 },
		{ 150, -44 }, { 160, 52 }, { 96, 60 }, { 132, -70, 1.15 },
		{ -150, -200 }, { -60, -206 }, { 60, -206 }, { 150, -200, 1.25 },
		{ -196, -120 }, { 196, -120 }, { -230, -30, 1.3 }, { 236, -20 },
	}
	local oaks = {
		{ -136, 30, 1.1 }, { -104, -10 }, { -140, -2 }, -- park cluster
		{ 118, 40 }, { -34, -74 }, { 34, -74 },
	}
	local rocks = { { -190, 80, 1.4 }, { -220, 10 }, { 226, 60, 1.2 }, { 190, 132 }, { 224, 148, 1.5 } }
	local flowers = {
		{ -12, 34 }, { 12, 34 }, { -126, 24 }, { -114, -4 },
		{ -96, -88 }, { -34, -88 }, { 34, -88 }, { 96, -88 },
		{ -96, -144 }, { 96, -144 }, { 124, 2 }, { -12, -34 }, { 12, -34 },
	}
	local function addAll(kind, list)
		for _, e in ipairs(list) do
			MapData.Nature[#MapData.Nature + 1] = { kind = kind, x = e[1], z = e[2], scale = e[3] or 1 }
		end
	end
	addAll("pine", pines)
	addAll("oak", oaks)
	addAll("rock", rocks)
	addAll("flowers", flowers)
end

-- NPC TOWNSFOLK ------------------------------------------------------------------------
-- kind: "wander" strolls near home; "post" stands at home point.
MapData.NPCs = {
	{
		id = "marisol", name = "Mayor Marisol", post = { 96, 8 }, y = 0.35, facing = 270, kind = "post",
		shirt = { 90, 110, 130 }, pants = { 60, 60, 70 }, skin = { 198, 152, 118 },
		lines = {
			"Welcome to Lanternside Bay! We're small, but the sunsets are enormous.",
			"Looking for work? The notice board in the square lists every open job.",
			"The cottages up the lane are free to claim. First come, first served!",
		},
	},
	{
		id = "pell", name = "Old Pell", post = { -4, 188 }, y = 2, facing = 90, kind = "post",
		shirt = { 200, 170, 90 }, pants = { 80, 90, 100 }, skin = { 170, 125, 95 },
		lines = {
			"Fish bite different after dark. Lantern eels, if you're lucky.",
			"A better rod means better fish. The General Store stocks two.",
			"I once pulled a bottle out of the bay with a note in it. Kept the note.",
		},
	},
	{
		id = "brine", name = "Captain Brine", post = { 4, 205 }, y = 2, facing = 180, kind = "post",
		shirt = { 40, 70, 110 }, pants = { 35, 40, 50 }, skin = { 210, 165, 130 },
		lines = {
			"The Pelican departs when she departs. Hop on at the end of the pier.",
			"Full loop of the bay, best view of the lighthouse. No charge. Mind the spray.",
		},
	},
	{
		id = "tilda", name = "Baker Tilda", post = { 6, -50 }, y = 0.4, facing = 180, kind = "post",
		shirt = { 220, 140, 130 }, pants = { 120, 90, 80 }, skin = { 245, 205, 170 },
		lines = {
			"Fresh batch every morning — well, whenever someone bakes one.",
			"Want the apron? Take the Baker job from the notice board and see me at the oven.",
		},
	},
	{
		id = "wren", name = "Wren", post = { -104, 22 }, facing = 90, kind = "post",
		shirt = { 150, 110, 170 }, pants = { 70, 80, 90 }, skin = { 225, 185, 150 },
		lines = {
			"I'm painting the lighthouse. Again. It keeps changing on me at dusk.",
			"The campfire crowd is friendly. Pull up a log.",
		},
	},
	{
		id = "sunny", name = "Sunny", post = { 64, 103 }, y = 2, facing = 180, kind = "post",
		shirt = { 250, 220, 120 }, pants = { 240, 240, 240 }, skin = { 190, 140, 105 },
		lines = {
			"Two scoops, one boardwalk, zero regrets. What'll it be?",
			"Sea-salt swirl is the local favorite. The seagulls agree, unfortunately.",
		},
	},
	{
		id = "milo", name = "Milo", post = { -30, 30 }, y = 0.5, facing = 0, kind = "wander", radius = 24,
		shirt = { 120, 170, 140 }, pants = { 90, 100, 110 }, skin = { 235, 195, 160 },
		lines = {
			"I've claimed Moonrise Cottage. Come by, I painted it seafoam!",
			"You can just... sit at the campfire and watch the ships. That's the whole activity. It's great.",
		},
	},
	{
		id = "posty", name = "Posty", post = { 86, 30 }, facing = 270, kind = "wander", radius = 8,
		shirt = { 200, 60, 60 }, pants = { 50, 50, 60 }, skin = { 205, 160, 125 },
		lines = {
			"Letters don't walk themselves up those lanes. Courier job's at the notice board.",
			"Every mailbox in town has a name on it. I know all of them by heart.",
		},
	},
}

return MapData
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0027">
<Properties>
<string name="Name">Monetization</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Monetization config

	HOW TO ACTIVATE (after publishing the game — takes ~5 minutes):
	1. Go to create.roblox.com → your experience → Monetization.
	2. Under "Passes", create each Game Pass below and paste its ID into `passId`.
	3. Under "Developer Products", create each coin pack and paste its ID into `productId`.
	4. Republish. Buttons in the in-game shop light up automatically once IDs are set.

	Anything left with an ID of 0 shows as "Coming soon" in-game and can't be
	bought — so this file is safe to ship exactly as-is.
]]

local Monetization = {}

-- DEVELOPER PRODUCTS (repeatable purchases) -----------------------------------
Monetization.Products = {
	{
		id = "coins_small", productId = 0,
		name = "Pocketful of Coins", coins = 400,
		icon = "🪙", desc = "400 coins for treats, rods, and paints.",
	},
	{
		id = "coins_medium", productId = 0,
		name = "Coin Satchel", coins = 1200,
		icon = "💰", desc = "1,200 coins — the popular one.",
	},
	{
		id = "coins_large", productId = 0,
		name = "Treasure Chest", coins = 3500,
		icon = "🏆", desc = "3,500 coins. Live like a lighthouse keeper.",
	},
}

-- GAME PASSES (one-time unlocks) ------------------------------------------------
Monetization.Passes = {
	{
		id = "vip", passId = 0,
		name = "Lanternside VIP",
		icon = "⭐", desc = "Golden name title, 2x job paychecks, +100 coins every visit, and the exclusive Spotlight emote.",
	},
	{
		id = "angler", passId = 0,
		name = "Master Angler",
		icon = "🎣", desc = "The Moonlit Rod (best luck in the bay) plus a glow trail when you hook something rare.",
	},
	{
		id = "deluxe_home", passId = 0,
		name = "Deluxe Cottage",
		icon = "🏠", desc = "Four premium paint palettes, a golden mailbox, and porch lanterns for your cottage.",
	},
	{
		id = "emotes", passId = 0,
		name = "Emote Pack",
		icon = "🕺", desc = "Every shop emote unlocked instantly, plus two exclusives: Backflip and Shrug.",
	},
}

-- Pass-only content ----------------------------------------------------------------
Monetization.VIPJoinBonus = 100
Monetization.VIPPayMultiplier = 2

Monetization.MoonlitRod = {
	id = "moonlit", name = "Moonlit Rod", price = nil, -- not coin-purchasable
	luck = 3.4, speed = 0.6, color = Color3.fromRGB(220, 230, 255),
}

Monetization.PremiumPalettes = {
	{ id = "sunset",   label = "Sunset Gold",   wall = Color3.fromRGB(235, 190, 120), trim = Color3.fromRGB(120, 70, 50) },
	{ id = "midnight", label = "Midnight",      wall = Color3.fromRGB(60, 70, 95),    trim = Color3.fromRGB(220, 225, 235) },
	{ id = "rosewood", label = "Rosewood",      wall = Color3.fromRGB(150, 80, 90),   trim = Color3.fromRGB(240, 225, 215) },
	{ id = "lagoon",   label = "Lagoon",        wall = Color3.fromRGB(80, 160, 165),  trim = Color3.fromRGB(245, 250, 248) },
}

Monetization.PassEmotes = {
	{ id = "emote_backflip", name = "Backflip", animId = "rbxassetid://507771845", pass = "emotes" },
	{ id = "emote_shrug",    name = "Shrug",    animId = "rbxassetid://507770818", pass = "emotes" },
	{ id = "emote_spotlight",name = "Spotlight",animId = "rbxassetid://507771406", pass = "vip" },
}

-- LOOKUPS ---------------------------------------------------------------------------
Monetization.ProductById = {}
for _, p in ipairs(Monetization.Products) do Monetization.ProductById[p.id] = p end
Monetization.PassById = {}
for _, p in ipairs(Monetization.Passes) do Monetization.PassById[p.id] = p end

function Monetization.findProductByRobloxId(productId)
	if productId == 0 then return nil end
	for _, p in ipairs(Monetization.Products) do
		if p.productId == productId then return p end
	end
	return nil
end

return Monetization
</ProtectedString>
</Properties>

</Item>
</Item>
</Item>
<Item class="ServerScriptService" referent="RBX0032">
<Properties>
<string name="Name">ServerScriptService</string>
</Properties>
<Item class="Script" referent="RBX0018">
<Properties>
<string name="Name">Main</string>
<ProtectedString name="Source">--[[
	═══════════════════════════════════════════════════════════════════
	  LANTERNSIDE BAY — server bootstrap
	  A cozy seaside roleplay town. Generated entirely from code.
	═══════════════════════════════════════════════════════════════════
	Boot order matters a little:
	  remotes -&gt; data -&gt; world -&gt; systems that wire onto the world.
]]

print("[Lanternside] Waking up the bay...")

local Remotes = require(script.Remotes)
local DataService = require(script.DataService)
local Economy = require(script.Economy)
local MonetizationService = require(script.MonetizationService)
local MapBuilder = require(script.MapBuilder)
local DayNight = require(script.DayNight)
local FishingService = require(script.FishingService)
local JobService = require(script.JobService)
local HousingService = require(script.HousingService)
local NPCService = require(script.NPCService)
local FerryService = require(script.FerryService)
local ShopService = require(script.ShopService)
local PlayerService = require(script.PlayerService)
local ChatSetup = require(script.ChatSetup)
local BotService = require(script.BotService)

local remotes = Remotes.init()
DataService.init()
Economy.init(remotes)

local worldRoot, anchors = MapBuilder.build()
print("[Lanternside] Town built: " .. #worldRoot:GetDescendants() .. " instances.")

ChatSetup.init()
DayNight.init(remotes, anchors.lighthouse)
MonetizationService.init(remotes, function(player)
	PlayerService.pushSnapshot(player)
end)
FishingService.init(remotes, DayNight.getHour, anchors.waterfront)
JobService.init(remotes, anchors)
HousingService.init(remotes, anchors)
NPCService.init(remotes, worldRoot)
FerryService.init(anchors.ferry)
ShopService.init(remotes, anchors, PlayerService.pushSnapshot)
PlayerService.init(remotes)
Economy.setSnapshotPusher(PlayerService.pushSnapshot)
BotService.init(anchors, DayNight.getHour)

print("[Lanternside] Open for visitors. 🌊")
</ProtectedString>
</Properties>
<Item class="ModuleScript" referent="RBX0001">
<Properties>
<string name="Name">BotService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — BotService
	"Scout", a resident bot that PLAYS the town so there's always something to
	watch: strolls the plaza, fishes off the pier (rod, bobber, splash and
	all), takes a coffee break, rides The Pelican around the bay, warms up at
	the campfire after dark, climbs to the lighthouse, dances by the fountain,
	and greets players who wander close.

	Implementation notes:
	* Same blocky body style as the townsfolk (anchored model, PivotTo motion)
	  so it fits the game's look and needs no animation rig.
	* Navigation is waypoint-based over the known MapData layout — routes carry
	  a Y so Scout steps up onto the boardwalk/pier decks and lighthouse stairs.
	* The ferry ride works by latching onto the hull: while aboard, Scout's
	  pivot is re-derived from the hull CFrame every frame.
	* Chat bubbles use the legacy Chat:Chat API (pcall-guarded) — still the
	  simplest server-side bubble, and harmless if it ever goes away.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ChatService = game:GetService("Chat")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local BK = require(script.Parent.BuildKit)

local BotService = {}

local WALK_SPEED = 12
local ARRIVE_DIST = 2.0

-- WAYPOINTS (x, z, y-of-ground) — derived from MapData's layout ------------------
local P = {
	plazaS = { 0, 44, 0.5 },
	plazaC = { 12, 20, 0.5 },
	fountain = { 0, 26, 0.5 },
	pathS = { 0, 82, 0 },
	boardwalk = { 0, 112, 2.0 },
	pierMid = { 0, 165, 2.0 },
	fishSpot = { -5, 175, 2.0 },
	ferryStop = { 4, 211, 2.0 },
	cafeDoor = { -56, -34, 0 },
	cafeIn = { -56, -46, 0.4 },
	cafeMachine = { -52, -56, 0.4 },
	cafeTable = { -47, -50, 0.4 },
	parkPath = { -74, 8, 0.35 },
	campfire = { -113, 22, 0 },
	laneAStreet = { 0, -94, 0.35 },
	laneAPorch = { -30, -99, 0 },
	bwEast = { 120, 110, 2.0 },
	walkwayEnd = { 184, 105, 2.0 },
	stairBase = { 192, 112, 2.6 },
	stairMid = { 192, 128, 4.2 },
	stairTop = { 192, 142, 5.4 },
	headland = { 200, 156, 5.4 },
	lighthouse = { 202, 162, 5.4 },
}

local function vec(p) return Vector3.new(p[1], p[3], p[2]) end -- (x, z, y) -&gt; Vector3

-- BODY ------------------------------------------------------------------------------
local function buildBody(parent, name)
	local m = BK.model("VisitorBot_" .. name, parent)
	local skin = Color3.fromRGB(224, 178, 144)
	local shirt = Color3.fromRGB(255, 140, 90)   -- bright — easy to spot from afar
	local pants = Color3.fromRGB(58, 76, 96)
	local base = CFrame.new(vec(P.plazaC))

	local root = BK.part({ Parent = m, Name = "Root", Size = Vector3.new(2, 0.4, 1.4),
		CFrame = base * CFrame.new(0, 0.2, 0), CanCollide = false })
	root.Transparency = 1
	local function limb(nm, size, offset, color, collide)
		return BK.part({ Parent = m, Name = nm, Size = size, Color = color,
			Material = Enum.Material.SmoothPlastic, CFrame = base * CFrame.new(offset),
			CanCollide = collide == true })
	end
	limb("LegL", Vector3.new(0.9, 2, 0.9), Vector3.new(-0.55, 1, 0), pants)
	limb("LegR", Vector3.new(0.9, 2, 0.9), Vector3.new(0.55, 1, 0), pants)
	limb("Torso", Vector3.new(2.2, 2.4, 1.2), Vector3.new(0, 3.2, 0), shirt, true)
	local armL = limb("ArmL", Vector3.new(0.8, 2.2, 0.8), Vector3.new(-1.55, 3.2, 0), shirt)
	local armR = limb("ArmR", Vector3.new(0.8, 2.2, 0.8), Vector3.new(1.55, 3.2, 0), shirt)
	local head = limb("Head", Vector3.new(1.5, 1.5, 1.5), Vector3.new(0, 5.2, 0), skin)
	-- a little adventurer's cap
	BK.part({ Parent = m, Name = "Cap", Size = Vector3.new(1.7, 0.5, 1.7),
		Color = Color3.fromRGB(50, 120, 110), Material = Enum.Material.Fabric,
		CFrame = base * CFrame.new(0, 6.05, 0), CanCollide = false })
	BK.part({ Parent = m, Name = "CapPeak", Size = Vector3.new(1.5, 0.2, 0.9),
		Color = Color3.fromRGB(50, 120, 110), Material = Enum.Material.Fabric,
		CFrame = base * CFrame.new(0, 5.95, -1.1), CanCollide = false })

	local face = Instance.new("SurfaceGui")
	face.Face = Enum.NormalId.Front
	face.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	face.PixelsPerStud = 40
	face.Parent = head
	local fl = Instance.new("TextLabel")
	fl.Size = UDim2.fromScale(1, 1)
	fl.BackgroundTransparency = 1
	fl.Font = Enum.Font.GothamBold
	fl.TextScaled = true
	fl.Text = "◠ ◠\n‿"
	fl.TextColor3 = Color3.fromRGB(40, 30, 25)
	fl.Parent = face

	BK.billboard(head, "🤖 " .. name .. "\nVisitor", Color3.fromRGB(150, 230, 210), 2.6, 120)

	m.PrimaryPart = root
	return m, head, armR
end

-- PROPS ---------------------------------------------------------------------------------
local function makeRod(model, armR)
	local rod = BK.part({ Parent = model, Name = "BotRod", Size = Vector3.new(0.25, 7, 0.25),
		Color = Color3.fromRGB(140, 110, 80), Material = Enum.Material.Wood, CanCollide = false })
	rod.CFrame = armR.CFrame * CFrame.new(0, -0.6, -2.2) * CFrame.Angles(math.rad(55), 0, 0)
	local bobber = BK.ball({ Parent = model, Name = "BotBobber", Size = Vector3.new(0.7, 0.7, 0.7),
		Color = Color3.fromRGB(230, 70, 60), Material = Enum.Material.Neon, CanCollide = false })
	return rod, bobber
end

local function makeCup(model, armR)
	local cup = BK.part({ Parent = model, Name = "BotCup", Size = Vector3.new(0.6, 0.8, 0.6),
		Color = Color3.fromRGB(245, 240, 230), Material = Enum.Material.SmoothPlastic, CanCollide = false })
	cup.CFrame = armR.CFrame * CFrame.new(0, -1.3, 0)
	return cup
end

-- CHAT ------------------------------------------------------------------------------------
local function bubble(head, text)
	pcall(function()
		ChatService:Chat(head, text, Enum.ChatColor.White)
	end)
end

-- THE BOT -----------------------------------------------------------------------------------
function BotService.init(anchors, getHour)
	local botCfg = Config.VisitorBot or { enabled = true, name = "Scout" }
	if botCfg.enabled == false then return end

	local model, head, armR = buildBody(game.Workspace, botCfg.name or "Scout")

	-- live motion state, driven by the Heartbeat loop below
	local pivot = CFrame.new(vec(P.plazaC))
	local target = nil            -- Vector3 currently walking toward
	local queue = {}              -- remaining Vector3 waypoints
	local ferryFollow = nil       -- hull part while aboard
	local ferryOffset = nil
	local walkPhase = 0

	local function goto_(points)  -- queue a route (list of P entries)
		queue = {}
		for _, p in ipairs(points) do
			queue[#queue + 1] = vec(p)
		end
		target = table.remove(queue, 1)
	end

	local function arrived()
		return target == nil and #queue == 0
	end

	-- Heartbeat: walk toward target, bob, face movement, or ride the ferry.
	RunService.Heartbeat:Connect(function(dt)
		if ferryFollow and ferryOffset then
			pivot = ferryFollow.CFrame * ferryOffset
			model:PivotTo(pivot)
			return
		end
		if target then
			local flat = Vector3.new(target.X - pivot.Position.X, 0, target.Z - pivot.Position.Z)
			local dist = flat.Magnitude
			if dist &lt; ARRIVE_DIST then
				target = table.remove(queue, 1)
			else
				local step = math.min(WALK_SPEED * dt, dist)
				local dir = flat.Unit
				local newPos = pivot.Position + dir * step
				-- ease toward the waypoint's ground height
				local y = pivot.Position.Y + (target.Y - pivot.Position.Y) * math.min(1, dt * 4)
				walkPhase = walkPhase + dt * 10
				local bob = math.abs(math.sin(walkPhase)) * 0.25
				pivot = CFrame.lookAt(Vector3.new(newPos.X, y, newPos.Z), Vector3.new(target.X, y, target.Z))
				model:PivotTo(pivot * CFrame.new(0, bob, 0))
				return
			end
		end
		-- idle: gentle breathing bob
		walkPhase = walkPhase + dt * 2
		model:PivotTo(pivot * CFrame.new(0, math.sin(walkPhase) * 0.08, 0))
	end)

	-- Greet players who come close (12s cooldown)
	local lastGreet = 0
	local GREETINGS = {
		"hey there! 👋", "nice day on the bay!", "have you tried the fishing?",
		"I'm saving up for the Starlight Rod", "the cocoa here is great",
	}
	task.spawn(function()
		while model.Parent do
			task.wait(2)
			if os.clock() - lastGreet &gt; 12 then
				for _, player in ipairs(Players:GetPlayers()) do
					local char = player.Character
					local hrp = char and char:FindFirstChild("HumanoidRootPart")
					if hrp and (hrp.Position - pivot.Position).Magnitude &lt; 9 then
						bubble(head, GREETINGS[math.random(#GREETINGS)])
						lastGreet = os.clock()
						break
					end
				end
			end
		end
	end)

	-- ACTIVITIES ------------------------------------------------------------------
	local function waitArrive(timeout)
		local t0 = os.clock()
		while not arrived() do
			task.wait(0.2)
			if os.clock() - t0 &gt; (timeout or 45) then
				-- unstick: snap to wherever we were headed
				local last = target or (queue[#queue])
				if last then
					pivot = CFrame.new(last)
					target = nil
					queue = {}
				end
				break
			end
		end
	end

	local function actFish()
		bubble(head, "off to catch dinner 🎣")
		goto_({ P.plazaS, P.pathS, P.boardwalk, P.pierMid, P.fishSpot })
		waitArrive()
		-- face the water (west of spot 1)
		pivot = CFrame.lookAt(pivot.Position, pivot.Position + Vector3.new(-1, 0, 0.2))
		local rod, bobber = makeRod(model, armR)
		for c = 1, 2 do
			bobber.CFrame = CFrame.new(pivot.Position + Vector3.new(-9, -2.6, 2))
			task.wait(3 + math.random() * 4)
			local splash = Instance.new("ParticleEmitter")
			splash.Rate = 0
			splash.Speed = NumberRange.new(4, 8)
			splash.Lifetime = NumberRange.new(0.4, 0.9)
			splash.SpreadAngle = Vector2.new(70, 70)
			splash.Color = ColorSequence.new(Color3.fromRGB(190, 225, 240))
			splash.Parent = bobber
			splash:Emit(20)
			bubble(head, c == 1 and "got one!! 🐟" or "TWO! today's my day 🐠")
			-- happy hop
			for _ = 1, 2 do
				model:PivotTo(pivot * CFrame.new(0, 1.2, 0))
				task.wait(0.12)
				model:PivotTo(pivot)
				task.wait(0.12)
			end
			task.wait(1)
		end
		rod:Destroy()
		bobber:Destroy()
	end

	local function actCafe()
		bubble(head, "coffee time ☕")
		goto_({ P.plazaS, P.cafeDoor, P.cafeIn, P.cafeMachine })
		waitArrive()
		task.wait(2.5)
		local cup = makeCup(model, armR)
		bubble(head, "one sea-salt latte, extra foam")
		goto_({ P.cafeTable })
		waitArrive()
		task.wait(6)
		cup:Destroy()
		bubble(head, "ok. best cafe on the coast.")
		goto_({ P.cafeIn, P.cafeDoor, P.plazaS })
		waitArrive()
	end

	local function actFerry()
		if not (anchors and anchors.ferry and anchors.ferry.hull) then return end
		local hull = anchors.ferry.hull
		bubble(head, "catching The Pelican ⛴️")
		goto_({ P.plazaS, P.pathS, P.boardwalk, P.pierMid, P.ferryStop })
		waitArrive()
		-- wait (up to a full loop) for the boat to dock nearby
		local t0 = os.clock()
		while (hull.Position - vec(P.ferryStop)).Magnitude &gt; 18 do
			task.wait(0.5)
			if os.clock() - t0 &gt; 150 then return end
		end
		-- hop aboard: stand on deck at the rail
		ferryOffset = CFrame.new(2.8, 2.5, 3.5)
		ferryFollow = hull
		bubble(head, "all aboard! 🌊")
		local rideStart = os.clock()
		task.wait(20)
		bubble(head, "look at the lighthouse from out here!")
		-- ride until we're back at the dock (or 4 minutes, whichever first)
		while os.clock() - rideStart &lt; 240 do
			task.wait(1)
			if os.clock() - rideStart &gt; 40 and (hull.Position - vec(P.ferryStop)).Magnitude &lt; 18 then
				break
			end
		end
		ferryFollow = nil
		ferryOffset = nil
		pivot = CFrame.new(vec(P.ferryStop))
		model:PivotTo(pivot)
		bubble(head, "what a ride 🌅")
	end

	local function actCampfire()
		bubble(head, "getting chilly — campfire! 🔥")
		goto_({ P.plazaS, P.parkPath, P.campfire })
		waitArrive()
		-- face the fire
		pivot = CFrame.lookAt(pivot.Position, Vector3.new(-120, pivot.Position.Y, 18))
		for _ = 1, 3 do
			task.wait(6)
		end
		bubble(head, "nothing beats a fire by the bay")
	end

	local function actLighthouse()
		bubble(head, "walking up to the lighthouse ⛯")
		goto_({ P.plazaS, P.pathS, P.boardwalk, P.bwEast, P.walkwayEnd, P.stairBase, P.stairMid, P.stairTop, P.headland, P.lighthouse })
		waitArrive(90)
		task.wait(4)
		bubble(head, "you can see the whole town from here!")
		task.wait(5)
		goto_({ P.headland, P.stairTop, P.stairMid, P.stairBase, P.walkwayEnd, P.bwEast, P.boardwalk })
		waitArrive(90)
	end

	local function actPlaza()
		goto_({ P.plazaS, P.fountain })
		waitArrive()
		bubble(head, "🎵")
		-- little spin dance by the fountain
		for i = 1, 10 do
			pivot = pivot * CFrame.Angles(0, math.rad(36), 0)
			model:PivotTo(pivot * CFrame.new(0, (i % 2) * 0.5, 0))
			task.wait(0.22)
		end
	end

	local function actCottages()
		bubble(head, "I love these little cottages 🏡")
		goto_({ P.plazaS, P.laneAStreet, P.laneAPorch })
		waitArrive()
		task.wait(4)
		bubble(head, "one day I'll claim one of my own")
		goto_({ P.laneAStreet, P.plazaS })
		waitArrive()
	end

	-- SCHEDULER: pick activities forever, weighted by time of day -----------------
	local DAY_ACTS = { actFish, actCafe, actFerry, actPlaza, actCottages, actLighthouse, actFish }
	local NIGHT_ACTS = { actCampfire, actFish, actLighthouse, actCampfire, actPlaza }

	task.spawn(function()
		task.wait(6) -- let the world and players settle in
		bubble(head, "hi, I'm " .. (botCfg.name or "Scout") .. "! just visiting 🤖")
		while model.Parent do
			local hour = getHour and getHour() or 12
			local night = hour &gt;= Config.NightStartHour or hour &lt; Config.NightEndHour
			local pool = night and NIGHT_ACTS or DAY_ACTS
			local act = pool[math.random(#pool)]
			local ok, err = pcall(act)
			if not ok then
				warn("[Lanternside] Bot activity error: " .. tostring(err))
				pivot = CFrame.new(vec(P.plazaC))
				model:PivotTo(pivot)
				target = nil
				queue = {}
				ferryFollow = nil
				ferryOffset = nil
			end
			task.wait(3 + math.random() * 5)
		end
	end)

	print("[Lanternside] Visitor bot '" .. (botCfg.name or "Scout") .. "' is out and about.")
end

return BotService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0002">
<Properties>
<string name="Name">BuildKit</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — BuildKit
	Low-level part/model helpers every builder uses. Keeping construction terse
	is what makes a fully code-generated town maintainable.
]]

local BuildKit = {}

function BuildKit.part(props)
	local p = Instance.new("Part")
	p.Anchored = true
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Material = props.Material or Enum.Material.SmoothPlastic
	p.Size = props.Size or Vector3.new(4, 1, 4)
	if props.CFrame then
		p.CFrame = props.CFrame
	elseif props.Position then
		p.Position = props.Position
	end
	p.Color = props.Color or Color3.fromRGB(200, 200, 200)
	p.Name = props.Name or "Part"
	p.Transparency = props.Transparency or 0
	p.CanCollide = (props.CanCollide ~= false)
	p.CastShadow = (props.CastShadow ~= false)
	if props.Shape then p.Shape = props.Shape end
	if props.Reflectance then p.Reflectance = props.Reflectance end
	p.Parent = props.Parent
	return p
end

function BuildKit.wedge(props)
	local p = Instance.new("WedgePart")
	p.Anchored = true
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Material = props.Material or Enum.Material.SmoothPlastic
	p.Size = props.Size or Vector3.new(4, 4, 4)
	p.CFrame = props.CFrame or CFrame.new()
	p.Color = props.Color or Color3.fromRGB(200, 200, 200)
	p.Name = props.Name or "Wedge"
	p.CanCollide = (props.CanCollide ~= false)
	p.Parent = props.Parent
	return p
end

function BuildKit.cylinder(props)
	props = props or {}
	local p = BuildKit.part(props)
	p.Shape = Enum.PartType.Cylinder
	return p
end

function BuildKit.ball(props)
	props = props or {}
	local p = BuildKit.part(props)
	p.Shape = Enum.PartType.Ball
	return p
end

function BuildKit.model(name, parent)
	local m = Instance.new("Model")
	m.Name = name
	m.Parent = parent
	return m
end

-- Ground-anchored CFrame helper: position at (x, z) with the part's base at ground
-- level `groundY`, given part height `h`, yaw in degrees.
function BuildKit.cfOnGround(x, z, h, yawDeg, groundY)
	groundY = groundY or 0
	return CFrame.new(x, groundY + h / 2, z) * CFrame.Angles(0, math.rad(yawDeg or 0), 0)
end

-- Simple text label on a part face (signs). Returns the SurfaceGui.
function BuildKit.faceText(part, face, text, textColor, scale)
	local gui = Instance.new("SurfaceGui")
	gui.Face = face
	gui.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	gui.PixelsPerStud = 32
	gui.Parent = part
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Fondamento
	label.Text = text
	label.TextColor3 = textColor or Color3.fromRGB(250, 245, 230)
	label.TextScaled = true
	label.Parent = gui
	local pad = Instance.new("UIPadding")
	local s = scale or 0.12
	pad.PaddingTop = UDim.new(s, 0)
	pad.PaddingBottom = UDim.new(s, 0)
	pad.PaddingLeft = UDim.new(s, 0)
	pad.PaddingRight = UDim.new(s, 0)
	pad.Parent = label
	return gui
end

-- Overhead billboard label (names over NPCs, cottages, stalls).
function BuildKit.billboard(parent, text, color, offsetY, maxDistance)
	local bb = Instance.new("BillboardGui")
	bb.Name = "Label"
	bb.Size = UDim2.fromOffset(220, 44)
	bb.StudsOffset = Vector3.new(0, offsetY or 3, 0)
	bb.AlwaysOnTop = false
	bb.MaxDistance = maxDistance or 90
	bb.Parent = parent
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.Text = text
	label.TextColor3 = color or Color3.fromRGB(255, 255, 255)
	label.TextStrokeTransparency = 0.35
	label.TextScaled = true
	label.Parent = bb
	return bb
end

-- A ProximityPrompt wired to a callback.
function BuildKit.prompt(parent, actionText, objectText, callback, holdDuration, distance)
	local pp = Instance.new("ProximityPrompt")
	pp.ActionText = actionText
	pp.ObjectText = objectText or ""
	pp.HoldDuration = holdDuration or 0
	pp.MaxActivationDistance = distance or 10
	pp.RequiresLineOfSight = false
	pp.Parent = parent
	if callback then pp.Triggered:Connect(callback) end
	return pp
end

-- Warm point light used by lamps, windows, the campfire...
function BuildKit.light(parent, color, range, brightness)
	local l = Instance.new("PointLight")
	l.Color = color or Color3.fromRGB(255, 205, 130)
	l.Range = range or 18
	l.Brightness = brightness or 1.4
	l.Shadows = false
	l.Enabled = false -- DayNight turns these on after dusk
	l.Parent = parent
	return l
end

-- Tag helper (CollectionService-style grouping without requiring the service everywhere)
function BuildKit.tag(instance, tagName)
	local CollectionService = game:GetService("CollectionService")
	CollectionService:AddTag(instance, tagName)
end

return BuildKit
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0003">
<Properties>
<string name="Name">Buildings</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Buildings
	Constructors for the town's structures: generic walls-roof-door shell plus
	per-kind interiors (cafe, bakery, store, town hall) and the claimable cottages.

	Every building is an open-door shell (no door part blocking entry) so walking
	in and out is seamless — social-RP games live and die on frictionless wandering.
]]

local BK = require(script.Parent.BuildKit)

local Buildings = {}

local WALL_T = 1.2 -- wall thickness

-- Builds a rectangular shell with a doorway on the facing side, windows, a
-- pitched roof, and a hanging sign. Returns model + useful attachment points.
function Buildings.shell(opts)
	local model = BK.model(opts.name or "Building", opts.parent)
	local w, h, d = opts.size[1], opts.size[2], opts.size[3]
	local x, z = opts.pos[1], opts.pos[2]
	local yaw = opts.facing or 180
	local wallColor = opts.wall or Color3.fromRGB(230, 220, 200)
	local trimColor = opts.trim or Color3.fromRGB(245, 245, 240)
	local roofColor = opts.roof or Color3.fromRGB(150, 60, 60)
	local base = CFrame.new(x, 0, z) * CFrame.Angles(0, math.rad(yaw), 0)
	-- In local space: -Z is the FRONT (door side) after this transform.

	local function place(offset, size, color, material, name, canCollide)
		return BK.part({
			Parent = model, Name = name or "Wall",
			Size = size, Color = color, Material = material or Enum.Material.Concrete,
			CFrame = base * CFrame.new(offset),
			CanCollide = canCollide,
		})
	end

	-- Floor
	place(Vector3.new(0, 0.2, 0), Vector3.new(w, 0.4, d), Color3.fromRGB(160, 130, 100), Enum.Material.WoodPlanks, "Floor")
	-- Back wall
	place(Vector3.new(0, h / 2, d / 2 - WALL_T / 2), Vector3.new(w, h, WALL_T), wallColor, nil, "BackWall")
	-- Side walls
	place(Vector3.new(-w / 2 + WALL_T / 2, h / 2, 0), Vector3.new(WALL_T, h, d), wallColor, nil, "SideWall")
	place(Vector3.new(w / 2 - WALL_T / 2, h / 2, 0), Vector3.new(WALL_T, h, d), wallColor, nil, "SideWall")
	-- Front wall with doorway: two flanks + header
	local doorW, doorH = 6, 7.5
	local flankW = (w - doorW) / 2
	place(Vector3.new(-(doorW / 2 + flankW / 2), h / 2, -d / 2 + WALL_T / 2), Vector3.new(flankW, h, WALL_T), wallColor, nil, "FrontWall")
	place(Vector3.new(doorW / 2 + flankW / 2, h / 2, -d / 2 + WALL_T / 2), Vector3.new(flankW, h, WALL_T), wallColor, nil, "FrontWall")
	place(Vector3.new(0, doorH + (h - doorH) / 2, -d / 2 + WALL_T / 2), Vector3.new(doorW, h - doorH, WALL_T), wallColor, nil, "DoorHeader")
	-- Door frame trim
	place(Vector3.new(-doorW / 2 - 0.4, doorH / 2, -d / 2 + WALL_T / 2), Vector3.new(0.8, doorH, WALL_T + 0.2), trimColor, Enum.Material.Wood, "Trim")
	place(Vector3.new(doorW / 2 + 0.4, doorH / 2, -d / 2 + WALL_T / 2), Vector3.new(0.8, doorH, WALL_T + 0.2), trimColor, Enum.Material.Wood, "Trim")

	-- Windows (glass, glow slightly at night via WindowLight tag)
	local winY = h * 0.55
	for _, wx in ipairs({ -w / 4 - doorW / 4, w / 4 + doorW / 4 }) do
		local win = place(Vector3.new(wx, winY, -d / 2 + WALL_T / 2), Vector3.new(3.4, 3.0, WALL_T + 0.15),
			Color3.fromRGB(190, 225, 235), Enum.Material.Glass, "Window", true)
		win.Transparency = 0.35
		BK.tag(win, "WindowGlow")
	end

	-- Pitched roof: two wedges meeting at a ridge. A WedgePart's tall vertical
	-- face is at its local +Z, so each half's tall face must point at the
	-- ridge (the building's center): front half unrotated, rear half spun 180.
	local roofH = math.max(4, h * 0.35)
	local halfD = d / 2 + 1
	BK.wedge({
		Parent = model, Name = "Roof", Color = roofColor, Material = Enum.Material.Slate,
		Size = Vector3.new(w + 2.5, roofH, halfD),
		CFrame = base * CFrame.new(0, h + roofH / 2, -halfD / 2),
	})
	BK.wedge({
		Parent = model, Name = "Roof", Color = roofColor, Material = Enum.Material.Slate,
		Size = Vector3.new(w + 2.5, roofH, halfD),
		CFrame = base * CFrame.new(0, h + roofH / 2, halfD / 2) * CFrame.Angles(0, math.rad(180), 0),
	})

	-- Hanging sign above the door
	if opts.sign then
		local signPart = place(Vector3.new(0, doorH + 1.8, -d / 2 - 0.8), Vector3.new(math.min(w - 4, 14), 2.4, 0.6),
			Color3.fromRGB(60, 46, 36), Enum.Material.Wood, "Sign", false)
		BK.faceText(signPart, Enum.NormalId.Front, opts.sign, Color3.fromRGB(250, 240, 210))
	end

	-- Warm interior light
	local lightAnchor = place(Vector3.new(0, h - 1.5, 0), Vector3.new(0.6, 0.6, 0.6), Color3.fromRGB(255, 240, 200), Enum.Material.Neon, "CeilingLamp", false)
	local pl = BK.light(lightAnchor, Color3.fromRGB(255, 225, 170), math.max(w, d) * 1.1, 1.2)
	pl.Enabled = true -- interiors stay warm all day
	BK.tag(lightAnchor, "InteriorLamp")

	return model, base, { w = w, h = h, d = d, doorH = doorH }
end

-- Small table with two stools; returns the table part (job targets glow it).
function Buildings.tableSet(parent, cf, tableColor)
	local m = BK.model("TableSet", parent)
	local top = BK.part({ Parent = m, Name = "TableTop", Size = Vector3.new(4.6, 0.4, 4.6),
		Color = tableColor or Color3.fromRGB(140, 105, 75), Material = Enum.Material.Wood, CFrame = cf * CFrame.new(0, 2.6, 0) })
	BK.part({ Parent = m, Name = "TableLeg", Size = Vector3.new(0.7, 2.4, 0.7),
		Color = Color3.fromRGB(110, 82, 58), Material = Enum.Material.Wood, CFrame = cf * CFrame.new(0, 1.2, 0) })
	for _, off in ipairs({ Vector3.new(-3.4, 0, 0), Vector3.new(3.4, 0, 0) }) do
		local seat = Instance.new("Seat")
		seat.Anchored = true
		seat.Size = Vector3.new(2, 0.6, 2)
		seat.Color = Color3.fromRGB(90, 70, 55)
		seat.Material = Enum.Material.Wood
		seat.CFrame = cf * CFrame.new(off.X, 1.4, off.Z)
		seat.Parent = m
		BK.part({ Parent = m, Name = "StoolLeg", Size = Vector3.new(0.6, 1.1, 0.6),
			Color = Color3.fromRGB(80, 62, 48), Material = Enum.Material.Wood, CFrame = cf * CFrame.new(off.X, 0.55, off.Z) })
	end
	return top
end

-- CAFE: espresso bar + machine + tables. Returns job anchors.
function Buildings.buildCafe(opts)
	local model, base = Buildings.shell(opts)
	-- Bar counter along the back
	BK.part({ Parent = model, Name = "BarCounter", Size = Vector3.new(opts.size[1] - 8, 3.4, 3),
		Color = Color3.fromRGB(96, 72, 56), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(0, 1.7, opts.size[3] / 2 - 4.5) })
	-- Espresso machine (the brew station)
	local machine = BK.part({ Parent = model, Name = "EspressoMachine", Size = Vector3.new(3, 2.2, 2),
		Color = Color3.fromRGB(170, 60, 60), Material = Enum.Material.Metal,
		CFrame = base * CFrame.new(-4, 4.5, opts.size[3] / 2 - 4.5) })
	BK.part({ Parent = model, Name = "Spout", Size = Vector3.new(0.5, 0.8, 0.9),
		Color = Color3.fromRGB(220, 220, 220), Material = Enum.Material.Metal,
		CFrame = base * CFrame.new(-4, 3.2, opts.size[3] / 2 - 5.4) })
	-- Order pickup point on the counter
	local orderSpot = BK.part({ Parent = model, Name = "OrderCounter", Size = Vector3.new(2.6, 0.3, 2.2),
		Color = Color3.fromRGB(230, 215, 190), Material = Enum.Material.Marble,
		CFrame = base * CFrame.new(4, 3.55, opts.size[3] / 2 - 4.5) })
	-- Guest tables; one of these gets highlighted as the delivery target
	local tables = {}
	tables[1] = Buildings.tableSet(model, base * CFrame.new(-9, 0, -2))
	tables[2] = Buildings.tableSet(model, base * CFrame.new(0, 0, 3))
	tables[3] = Buildings.tableSet(model, base * CFrame.new(9, 0, -2))
	return model, { machine = machine, orderSpot = orderSpot, tables = tables }
end

-- BAKERY: kneading counter, oven, display shelf.
function Buildings.buildBakery(opts)
	local model, base = Buildings.shell(opts)
	local counter = BK.part({ Parent = model, Name = "KneadCounter", Size = Vector3.new(7, 3.2, 3),
		Color = Color3.fromRGB(225, 210, 185), Material = Enum.Material.Marble,
		CFrame = base * CFrame.new(-7, 1.6, opts.size[3] / 2 - 4.5) })
	local oven = BK.part({ Parent = model, Name = "Oven", Size = Vector3.new(5, 5, 3.4),
		Color = Color3.fromRGB(70, 70, 75), Material = Enum.Material.Metal,
		CFrame = base * CFrame.new(4, 2.5, opts.size[3] / 2 - 4.3) })
	local ovenGlow = BK.part({ Parent = model, Name = "OvenGlow", Size = Vector3.new(3.2, 2.2, 0.3),
		Color = Color3.fromRGB(255, 140, 60), Material = Enum.Material.Neon,
		CFrame = base * CFrame.new(4, 2.1, opts.size[3] / 2 - 6.05), CanCollide = false })
	ovenGlow.Transparency = 0.4
	local shelf = BK.part({ Parent = model, Name = "BreadShelf", Size = Vector3.new(6, 4.4, 1.6),
		Color = Color3.fromRGB(140, 105, 75), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(opts.size[1] / 2 - 2.2, 2.2, -3) })
	Buildings.tableSet(model, base * CFrame.new(-8, 0, -4))
	return model, { counter = counter, oven = oven, shelf = shelf }
end

-- GENERAL STORE: shelves + shop counter (opens the shop UI).
function Buildings.buildStore(opts)
	local model, base = Buildings.shell(opts)
	local counter = BK.part({ Parent = model, Name = "ShopCounter", Size = Vector3.new(8, 3.4, 3),
		Color = Color3.fromRGB(96, 72, 56), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(0, 1.7, opts.size[3] / 2 - 4.5) })
	for i = -1, 1, 2 do
		BK.part({ Parent = model, Name = "Shelf", Size = Vector3.new(1.6, 6, opts.size[3] - 10),
			Color = Color3.fromRGB(150, 115, 85), Material = Enum.Material.Wood,
			CFrame = base * CFrame.new(i * (opts.size[1] / 2 - 3), 3, -1) })
	end
	-- A couple of crates for flavor
	for _, off in ipairs({ Vector3.new(-6, 1, -8), Vector3.new(-4.2, 1, -7), Vector3.new(-5.2, 3, -7.6) }) do
		BK.part({ Parent = model, Name = "Crate", Size = Vector3.new(2, 2, 2),
			Color = Color3.fromRGB(170, 140, 100), Material = Enum.Material.WoodPlanks, CFrame = base * CFrame.new(off) })
	end
	return model, { counter = counter }
end

-- TOWN HALL: post desk (courier job), notice-board-style interior, benches.
function Buildings.buildTownHall(opts)
	local model, base = Buildings.shell(opts)
	local desk = BK.part({ Parent = model, Name = "PostDesk", Size = Vector3.new(9, 3.4, 3),
		Color = Color3.fromRGB(110, 85, 60), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(0, 1.7, opts.size[3] / 2 - 5) })
	BK.faceText(BK.part({ Parent = model, Name = "PostSign", Size = Vector3.new(9, 1.6, 0.4),
		Color = Color3.fromRGB(60, 46, 36), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(0, 6.4, opts.size[3] / 2 - 5), CanCollide = false }),
		Enum.NormalId.Front, "POST OFFICE")
	-- Letter cubbies behind the desk
	BK.part({ Parent = model, Name = "Cubbies", Size = Vector3.new(9, 5, 1.2),
		Color = Color3.fromRGB(140, 108, 78), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(0, 2.5, opts.size[3] / 2 - 1.4) })
	for i = -1, 1, 2 do
		local bench = Instance.new("Seat")
		bench.Anchored = true
		bench.Size = Vector3.new(7, 1, 2.2)
		bench.Color = Color3.fromRGB(120, 95, 70)
		bench.Material = Enum.Material.Wood
		bench.CFrame = base * CFrame.new(i * 9, 1.2, -4)
		bench.Parent = model
	end
	return model, { desk = desk }
end

-- COTTAGE: cozy claimable home — porch, mailbox, name sign, bed, lamp, two seats.
function Buildings.buildCottage(opts)
	local model, base, dims = Buildings.shell({
		name = opts.name, parent = opts.parent,
		pos = opts.pos, size = opts.size, facing = opts.facing,
		wall = opts.wall, trim = opts.trim, roof = opts.roof or Color3.fromRGB(120, 90, 70),
		sign = nil, -- cottages get a billboard name instead of a face sign
	})
	local w, d = opts.size[1], opts.size[3]

	-- Porch slab + posts
	BK.part({ Parent = model, Name = "Porch", Size = Vector3.new(w * 0.7, 0.8, 5),
		Color = Color3.fromRGB(150, 120, 92), Material = Enum.Material.WoodPlanks,
		CFrame = base * CFrame.new(0, 0.4, -d / 2 - 2.5) })
	for i = -1, 1, 2 do
		BK.part({ Parent = model, Name = "PorchPost", Size = Vector3.new(0.7, 6, 0.7),
			Color = Color3.fromRGB(130, 104, 80), Material = Enum.Material.Wood,
			CFrame = base * CFrame.new(i * (w * 0.35 - 0.6), 3.8, -d / 2 - 4.4) })
	end

	-- Bed (with a Seat "lie down" spot)
	local bed = BK.model("Bed", model)
	BK.part({ Parent = bed, Name = "BedFrame", Size = Vector3.new(4.4, 1.2, 7),
		Color = Color3.fromRGB(120, 92, 66), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(-w / 2 + 3.4, 0.8, d / 2 - 4.6) })
	BK.part({ Parent = bed, Name = "Mattress", Size = Vector3.new(4, 0.8, 6.4),
		Color = Color3.fromRGB(240, 238, 230), Material = Enum.Material.Fabric,
		CFrame = base * CFrame.new(-w / 2 + 3.4, 1.75, d / 2 - 4.6) })
	BK.part({ Parent = bed, Name = "Quilt", Size = Vector3.new(4.05, 0.5, 3.6),
		Color = opts.quilt or Color3.fromRGB(120, 160, 190), Material = Enum.Material.Fabric,
		CFrame = base * CFrame.new(-w / 2 + 3.4, 2.05, d / 2 - 3.4) })
	BK.part({ Parent = bed, Name = "Pillow", Size = Vector3.new(2.6, 0.6, 1.6),
		Color = Color3.fromRGB(250, 250, 245), Material = Enum.Material.Fabric,
		CFrame = base * CFrame.new(-w / 2 + 3.4, 2.15, d / 2 - 6.6) })
	local bedSeat = Instance.new("Seat")
	bedSeat.Anchored = true
	bedSeat.Transparency = 1
	bedSeat.Size = Vector3.new(3, 0.4, 3)
	bedSeat.CFrame = base * CFrame.new(-w / 2 + 3.4, 2.4, d / 2 - 4.6)
	bedSeat.Parent = bed

	-- Fireside chairs
	for i = -1, 1, 2 do
		local chair = Instance.new("Seat")
		chair.Anchored = true
		chair.Size = Vector3.new(2.4, 0.8, 2.4)
		chair.Color = Color3.fromRGB(150, 110, 90)
		chair.Material = Enum.Material.Fabric
		chair.CFrame = base * CFrame.new(w / 2 - 5 + (i * 1.8), 1.2, d / 2 - 5 - (i * 2))
		chair.Parent = model
		BK.part({ Parent = model, Name = "ChairBack", Size = Vector3.new(2.4, 2.6, 0.6),
			Color = Color3.fromRGB(140, 100, 82), Material = Enum.Material.Fabric,
			CFrame = chair.CFrame * CFrame.new(0, 1.4, 1.2) })
	end

	-- Table lamp on a side table (toggleable by the owner later; glows at night)
	local sideTable = BK.part({ Parent = model, Name = "SideTable", Size = Vector3.new(2, 2.2, 2),
		Color = Color3.fromRGB(130, 100, 75), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(w / 2 - 3, 1.1, -d / 2 + 4) })
	local lampShade = BK.part({ Parent = model, Name = "CottageLampShade", Size = Vector3.new(1.2, 1.1, 1.2),
		Color = Color3.fromRGB(255, 230, 180), Material = Enum.Material.Neon,
		CFrame = sideTable.CFrame * CFrame.new(0, 1.8, 0), CanCollide = false })
	BK.light(lampShade, Color3.fromRGB(255, 220, 160), 14, 1.1)
	BK.tag(lampShade, "NightLamp")

	-- Mailbox out front (courier target)
	local mailbox = BK.model("Mailbox", model)
	BK.part({ Parent = mailbox, Name = "MailPost", Size = Vector3.new(0.5, 3.4, 0.5),
		Color = Color3.fromRGB(90, 70, 55), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(w / 2 - 2, 1.7, -d / 2 - 7) })
	local mailBody = BK.part({ Parent = mailbox, Name = "MailBody", Size = Vector3.new(1.4, 1.2, 2.2),
		Color = Color3.fromRGB(70, 110, 160), Material = Enum.Material.Metal,
		CFrame = base * CFrame.new(w / 2 - 2, 3.9, -d / 2 - 7) })
	mailbox.PrimaryPart = mailBody

	-- Claim sign by the door
	local claimSign = BK.part({ Parent = model, Name = "ClaimSign", Size = Vector3.new(2.6, 3.2, 0.5),
		Color = Color3.fromRGB(96, 76, 58), Material = Enum.Material.Wood,
		CFrame = base * CFrame.new(-w / 2 + 2.4, 1.6, -d / 2 - 4) })

	model.PrimaryPart = claimSign
	return model, {
		claimSign = claimSign,
		mailbox = mailBody,
		bedSeat = bedSeat,
		base = base,
	}
end

return Buildings
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0004">
<Properties>
<string name="Name">ChatSetup</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — ChatSetup
	Turn on bubble chat (RP towns are all about the over-the-head chatter) and
	style it gently. Wrapped in pcall — chat configuration instances vary a
	little across Roblox versions and none of this is worth crashing over.
]]

local TextChatService = game:GetService("TextChatService")

local ChatSetup = {}

function ChatSetup.init()
	pcall(function()
		local bubble = TextChatService:FindFirstChildOfClass("BubbleChatConfiguration")
		if bubble then
			bubble.Enabled = true
			bubble.BackgroundColor3 = Color3.fromRGB(250, 247, 240)
			bubble.TextColor3 = Color3.fromRGB(45, 40, 35)
			bubble.MaxDistance = 90
		end
		local window = TextChatService:FindFirstChildOfClass("ChatWindowConfiguration")
		if window then
			window.Enabled = true
		end
	end)
end

return ChatSetup
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0005">
<Properties>
<string name="Name">DataService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — DataService
	DataStore persistence with a safe in-memory fallback (Studio without API
	access, or DataStore outages, never break play — progress just doesn't
	persist in those cases).
]]

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local RunService = game:GetService("RunService")

local Config = require(game:GetService("ReplicatedStorage").Shared.Config)

local DataService = {}

local store = nil
local storeOk = pcall(function()
	store = DataStoreService:GetDataStore(Config.DataStoreName)
end)

local sessions = {} -- player -&gt; data table
local dirty = {}    -- player -&gt; true when unsaved changes exist

local function defaultData()
	return {
		coins = Config.StartingCoins,
		rodId = "driftwood",
		ownedRods = { driftwood = true },
		ownedEmotes = {},
		fish = {},            -- fishId -&gt; count (carried, unsold)
		totalCatches = 0,
		tasksCompleted = 0,
		cottagePaint = "seafoam",
		roleTitleIndex = 1,
		grantedReceipts = {}, -- PurchaseId -&gt; true (dev product idempotency)
		firstJoin = true,
	}
end

local function keyFor(player)
	return "p_" .. player.UserId
end

function DataService.load(player)
	local data = defaultData()
	if store and storeOk then
		local ok, saved = pcall(function()
			return store:GetAsync(keyFor(player))
		end)
		if ok and type(saved) == "table" then
			for k, v in pairs(saved) do
				data[k] = v
			end
			data.firstJoin = false
		end
	end
	sessions[player] = data
	return data
end

function DataService.get(player)
	return sessions[player]
end

function DataService.markDirty(player)
	dirty[player] = true
end

local function saveNow(player)
	local data = sessions[player]
	if not data then return end
	if not (store and storeOk) then return end
	local toSave = {}
	for k, v in pairs(data) do
		if k ~= "firstJoin" then toSave[k] = v end
	end
	pcall(function()
		store:SetAsync(keyFor(player), toSave)
	end)
	dirty[player] = nil
end

function DataService.release(player)
	saveNow(player)
	sessions[player] = nil
	dirty[player] = nil
end

function DataService.init()
	-- Autosave loop
	task.spawn(function()
		while true do
			task.wait(Config.AutosaveIntervalSeconds)
			for player in pairs(dirty) do
				if sessions[player] then
					saveNow(player)
				end
			end
		end
	end)
	-- Save everyone on shutdown
	game:BindToClose(function()
		if RunService:IsStudio() then return end
		for _, player in ipairs(Players:GetPlayers()) do
			saveNow(player)
		end
	end)
end

return DataService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0006">
<Properties>
<string name="Name">DayNight</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — DayNight
	Drives Lighting.ClockTime on a continuous loop, toggles the streetlamps,
	cottage lamps, and window glow, and spins the lighthouse beam after dark.
	The current hour is shared with other systems (fishing night bonuses) and
	broadcast to clients for the HUD clock.
]]

local Lighting = game:GetService("Lighting")
local CollectionService = game:GetService("CollectionService")
local RunService = game:GetService("RunService")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)

local DayNight = {}

local remotes = nil
local lighthouse = nil
local currentHour = 12
local nightActive = nil -- tri-state so the first tick always applies

function DayNight.getHour()
	return currentHour
end

function DayNight.isNight()
	return currentHour &gt;= Config.NightStartHour or currentHour &lt; Config.NightEndHour
end

local function applyBaseLighting()
	-- Technology is set in the place file (not scriptable at runtime); this
	-- pcall is just a harmless nudge for Studio sessions where it isn't.
	pcall(function()
		Lighting.Technology = Enum.Technology.Future
	end)
	Lighting.Brightness = 2.4
	Lighting.EnvironmentDiffuseScale = 0.7
	Lighting.EnvironmentSpecularScale = 0.6
	Lighting.OutdoorAmbient = Color3.fromRGB(90, 96, 105)
	Lighting.Ambient = Color3.fromRGB(70, 74, 82)
	Lighting.GlobalShadows = true
	Lighting.ClockTime = 12

	local atmosphere = Instance.new("Atmosphere")
	atmosphere.Density = 0.32
	atmosphere.Offset = 0.4
	atmosphere.Color = Color3.fromRGB(199, 199, 199)
	atmosphere.Decay = Color3.fromRGB(120, 130, 150)
	atmosphere.Glare = 0.25
	atmosphere.Haze = 1.2
	atmosphere.Parent = Lighting

	local bloom = Instance.new("BloomEffect")
	bloom.Intensity = 0.6
	bloom.Size = 28
	bloom.Threshold = 1.1
	bloom.Parent = Lighting

	local cc = Instance.new("ColorCorrectionEffect")
	cc.Name = "TimeGrade"
	cc.Parent = Lighting
end

local function setNight(isNight)
	if nightActive == isNight then return end
	nightActive = isNight
	for _, head in ipairs(CollectionService:GetTagged("NightLamp")) do
		local light = head:FindFirstChildOfClass("PointLight")
		if light then light.Enabled = isNight end
		if head:IsA("BasePart") then
			head.Transparency = isNight and 0.05 or 0.55
		end
	end
	for _, win in ipairs(CollectionService:GetTagged("WindowGlow")) do
		win.Material = isNight and Enum.Material.Neon or Enum.Material.Glass
		win.Color = isNight and Color3.fromRGB(255, 226, 170) or Color3.fromRGB(190, 225, 235)
	end
	if lighthouse then
		lighthouse.light.Enabled = isNight
		lighthouse.beam.Transparency = isNight and 0.55 or 1
		lighthouse.core.Color = isNight and Color3.fromRGB(255, 235, 170) or Color3.fromRGB(200, 200, 195)
	end
end

function DayNight.init(remoteMap, lighthouseAnchors)
	remotes = remoteMap
	lighthouse = lighthouseAnchors
	applyBaseLighting()

	local dayLengthSeconds = Config.DayLengthMinutes * 60
	local hoursPerSecond = 24 / dayLengthSeconds
	currentHour = 9 -- servers start on a fresh morning
	local beamAngle = 0
	local sinceBroadcast = 0

	RunService.Heartbeat:Connect(function(dt)
		currentHour = (currentHour + dt * hoursPerSecond) % 24
		Lighting.ClockTime = currentHour
		setNight(DayNight.isNight())

		-- Golden-hour grading: warm tint near sunrise/sunset, cool tint at night
		local grade = Lighting:FindFirstChild("TimeGrade")
		if grade then
			local h = currentHour
			if h &gt; 17 and h &lt; 19.5 then
				grade.TintColor = Color3.fromRGB(255, 235, 215)
				grade.Saturation = 0.08
			elseif h &gt;= 19.5 or h &lt; 5.5 then
				grade.TintColor = Color3.fromRGB(212, 222, 244)
				grade.Saturation = -0.08
			elseif h &gt;= 5.5 and h &lt; 7.5 then
				grade.TintColor = Color3.fromRGB(255, 240, 225)
				grade.Saturation = 0.05
			else
				grade.TintColor = Color3.fromRGB(255, 255, 255)
				grade.Saturation = 0
			end
		end

		-- Lighthouse beam sweep
		if nightActive and lighthouse then
			beamAngle = (beamAngle + dt * 0.7) % (math.pi * 2)
			local pivotCF = lighthouse.topCF * CFrame.Angles(0, beamAngle, 0)
			lighthouse.pivot.CFrame = pivotCF
			lighthouse.beam.CFrame = pivotCF * CFrame.new(0, 0, -48)
		end

		-- HUD clock broadcast (4x a second is plenty smooth for a clock)
		sinceBroadcast = sinceBroadcast + dt
		if sinceBroadcast &gt;= 0.25 then
			sinceBroadcast = 0
			remotes.events.TimeOfDay:FireAllClients(currentHour)
		end
	end)
end

return DayNight
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0007">
<Properties>
<string name="Name">Economy</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Economy
	Coins live server-side only. Leaderstats mirror them onto the player list
	(social proof is half the fun in an RP town).
]]

local DataService = require(script.Parent.DataService)

local Economy = {}

local remotes = nil
local pushSnapshot = nil

function Economy.init(remoteMap)
	remotes = remoteMap
end

-- Injected by Main (PlayerService.pushSnapshot) so every balance change
-- reaches the client HUD immediately — fishing sales and job pay included.
function Economy.setSnapshotPusher(fn)
	pushSnapshot = fn
end

function Economy.setupLeaderstats(player)
	local stats = Instance.new("Folder")
	stats.Name = "leaderstats"
	stats.Parent = player
	local coins = Instance.new("IntValue")
	coins.Name = "Coins"
	coins.Value = 0
	coins.Parent = stats
	local catches = Instance.new("IntValue")
	catches.Name = "Catches"
	catches.Value = 0
	catches.Parent = stats
	Economy.refresh(player)
end

function Economy.refresh(player)
	local data = DataService.get(player)
	if not data then return end
	local stats = player:FindFirstChild("leaderstats")
	if stats then
		local coins = stats:FindFirstChild("Coins")
		if coins then coins.Value = data.coins end
		local catches = stats:FindFirstChild("Catches")
		if catches then catches.Value = data.totalCatches end
	end
	if pushSnapshot then
		pushSnapshot(player)
	end
end

function Economy.getCoins(player)
	local data = DataService.get(player)
	return data and data.coins or 0
end

function Economy.addCoins(player, amount, reason)
	if amount == 0 then return true end
	local data = DataService.get(player)
	if not data then return false end
	data.coins = math.max(0, data.coins + amount)
	DataService.markDirty(player)
	Economy.refresh(player)
	if remotes and amount &gt; 0 then
		remotes.events.Toast:FireClient(player, "+" .. amount .. " coins" .. (reason and (" — " .. reason) or ""), "coins")
	end
	return true
end

function Economy.spendCoins(player, amount)
	local data = DataService.get(player)
	if not data then return false end
	if data.coins &lt; amount then return false end
	data.coins = data.coins - amount
	DataService.markDirty(player)
	Economy.refresh(player)
	return true
end

return Economy
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0008">
<Properties>
<string name="Name">FerryService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — FerryService
	The Pelican sails a fixed loop around the bay. The whole boat is anchored;
	we move it by CFrame each Heartbeat, pausing at the dock so riders can
	board. Seated players ride along automatically (sitting welds them on).
]]

local RunService = game:GetService("RunService")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MapData = require(ReplicatedStorage.Shared.MapData)

local FerryService = {}

local DOCK_WAIT_SECONDS = 12

function FerryService.init(ferryAnchors)
	local boat = ferryAnchors.boat
	local route = {}
	-- Route starts/ends at the dock position so the pause happens shoreside.
	local dock = MapData.FerryDock
	route[1] = Vector3.new(dock.x + 6, 0.2, dock.z)
	for _, wp in ipairs(MapData.FerryRoute) do
		route[#route + 1] = Vector3.new(wp[1], 0.2, wp[2])
	end
	route[#route + 1] = route[1]

	local segment = 1
	local progress = 0 -- studs traveled along current segment
	local waiting = DOCK_WAIT_SECONDS -- start docked

	RunService.Heartbeat:Connect(function(dt)
		if waiting &gt; 0 then
			waiting = waiting - dt
			return
		end
		local from = route[segment]
		local to = route[segment + 1]
		if not to then
			segment = 1
			progress = 0
			waiting = DOCK_WAIT_SECONDS
			return
		end
		local segVec = to - from
		local segLen = segVec.Magnitude
		progress = progress + MapData.FerrySpeed * dt
		if progress &gt;= segLen then
			progress = progress - segLen
			segment = segment + 1
			if segment &gt;= #route then
				segment = 1
				progress = 0
				waiting = DOCK_WAIT_SECONDS
			end
			return
		end
		local pos = from + segVec.Unit * progress
		-- Gentle bob + face direction of travel (the bow is built at local -Z,
		-- which is exactly where lookAt points the LookVector — no flip needed)
		local bob = math.sin(os.clock() * 1.4) * 0.25
		local look = CFrame.lookAt(pos, pos + Vector3.new(segVec.X, 0, segVec.Z))
		boat:PivotTo(look * CFrame.new(0, bob, 0))
	end)
end

return FerryService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0009">
<Properties>
<string name="Name">FishingService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — FishingService
	Server-authoritative fishing: the server rolls the fish, times the bite,
	and enforces rate limits + proximity; the client only renders and reacts.
]]

local Players = game:GetService("Players")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local Catalog = require(ReplicatedStorage.Shared.Catalog)
local MapData = require(ReplicatedStorage.Shared.MapData)
local Monetization = require(ReplicatedStorage.Shared.Monetization)
local DataService = require(script.Parent.DataService)
local Economy = require(script.Parent.Economy)

local FishingService = {}

local remotes = nil
local getHour = nil -- injected from DayNight
local casts = {} -- player -&gt; { state = "waiting"|"bite", spot, fish, biteAt, escapeAt, lastCast }

local function rodFor(player)
	local data = DataService.get(player)
	local rodId = data and data.rodId or "driftwood"
	if rodId == "moonlit" then
		return Monetization.MoonlitRod
	end
	return Catalog.RodById[rodId] or Catalog.RodById.driftwood
end

local function isNight()
	local h = getHour and getHour() or 12
	return h &gt;= Config.NightStartHour or h &lt; Config.NightEndHour
end

local function rollFish(rod)
	local night = isNight()
	local pool = {}
	local total = 0
	for _, f in ipairs(Catalog.Fish) do
		local ok = true
		if f.nightOnly and not night then ok = false end
		if f.dayOnly and night then ok = false end
		if ok then
			local w = f.weight
			if f.rarity == "rare" or f.rarity == "epic" then
				w = w * rod.luck
				if night then w = w * Config.Fishing.NightRareBonus end
			end
			total = total + w
			pool[#pool + 1] = { fish = f, cum = total }
		end
	end
	local r = math.random() * total
	for _, entry in ipairs(pool) do
		if r &lt;= entry.cum then return entry.fish end
	end
	return pool[#pool].fish
end

local function charPosition(player)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	return hrp and hrp.Position or nil
end

local function nearSpot(player, spotIndex)
	local spot = MapData.FishingSpots[spotIndex]
	if not spot then return false end
	local pos = charPosition(player)
	if not pos then return false end
	local dx = pos.X - spot[1]
	local dz = pos.Z - spot[2]
	return (dx * dx + dz * dz) &lt;= (Config.MaxInteractDistance * Config.MaxInteractDistance)
end

local function onCastLine(player, spotIndex)
	if type(spotIndex) ~= "number" then return end
	local data = DataService.get(player)
	if not data then return end
	local session = casts[player] or {}
	local now = os.clock()
	if session.lastCast and (now - session.lastCast) &lt; Config.Fishing.MinCastIntervalSeconds then
		return -- rate limited
	end
	if not nearSpot(player, spotIndex) then
		remotes.events.Toast:FireClient(player, "Get closer to a fishing spot!", "warn")
		return
	end
	local carried = 0
	for _, count in pairs(data.fish) do carried = carried + count end
	if carried &gt;= Config.Fishing.MaxFishInventory then
		remotes.events.Toast:FireClient(player, "Your basket is full — sell at the Fish Market!", "warn")
		return
	end

	local rod = rodFor(player)
	local wait = (Config.Fishing.BiteTimeMin + math.random() * (Config.Fishing.BiteTimeMax - Config.Fishing.BiteTimeMin)) * rod.speed
	session.state = "waiting"
	session.spot = spotIndex
	session.fish = rollFish(rod)
	session.biteAt = now + wait
	session.escapeAt = nil
	session.lastCast = now
	casts[player] = session
	remotes.events.FishingState:FireClient(player, "cast", { spot = spotIndex })

	task.delay(wait, function()
		local s = casts[player]
		if s and s.state == "waiting" and s.biteAt and math.abs((s.biteAt) - (now + wait)) &lt; 0.01 then
			s.state = "bite"
			s.escapeAt = os.clock() + Config.Fishing.ReactionWindowSeconds
			remotes.events.FishingState:FireClient(player, "bite", {})
			task.delay(Config.Fishing.ReactionWindowSeconds, function()
				local s2 = casts[player]
				if s2 and s2.state == "bite" and s2.escapeAt and os.clock() &gt;= s2.escapeAt then
					s2.state = nil
					remotes.events.FishingState:FireClient(player, "escaped", {})
				end
			end)
		end
	end)
end

local function onReelIn(player)
	local session = casts[player]
	local data = DataService.get(player)
	if not session or not data then return end
	if session.state ~= "bite" then
		if session.state == "waiting" then
			session.state = nil
			remotes.events.FishingState:FireClient(player, "reeled_early", {})
		end
		return
	end
	local fish = session.fish
	session.state = nil
	session.escapeAt = nil
	data.fish[fish.id] = (data.fish[fish.id] or 0) + 1
	data.totalCatches = data.totalCatches + 1
	DataService.markDirty(player)
	Economy.refresh(player)
	remotes.events.FishingState:FireClient(player, "caught", {
		fishId = fish.id, name = fish.name, rarity = fish.rarity, value = fish.value,
	})
	-- Master Angler flair on rare+ catches (visible to everyone nearby)
	if (fish.rarity == "rare" or fish.rarity == "epic") then
		local char = player.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if hrp then
			local sparkle = Instance.new("ParticleEmitter")
			sparkle.Rate = 0
			sparkle.Lifetime = NumberRange.new(0.6, 1.2)
			sparkle.Speed = NumberRange.new(6, 10)
			sparkle.SpreadAngle = Vector2.new(180, 180)
			sparkle.Color = ColorSequence.new(Catalog.RarityColors[fish.rarity])
			sparkle.LightEmission = 1
			sparkle.Parent = hrp
			sparkle:Emit(24)
			task.delay(2, function() sparkle:Destroy() end)
		end
	end
end

local function onSellFish(player)
	local data = DataService.get(player)
	if not data then return end
	-- Proximity: must be near the fish market
	local pos = charPosition(player)
	local mk = MapData.MarketStall
	if not pos then return end
	local dx, dz = pos.X - mk.x, pos.Z - mk.z
	if (dx * dx + dz * dz) &gt; (Config.MaxInteractDistance * Config.MaxInteractDistance) * 4 then
		remotes.events.Toast:FireClient(player, "Sell at the Fish Market on the boardwalk.", "warn")
		return
	end
	local totalValue = 0
	local totalCount = 0
	for fishId, count in pairs(data.fish) do
		local f = Catalog.FishById[fishId]
		if f then
			totalValue = totalValue + f.value * count
			totalCount = totalCount + count
		end
	end
	if totalCount == 0 then
		remotes.events.Toast:FireClient(player, "No fish to sell — cast a line off the pier!", "info")
		return
	end
	data.fish = {}
	DataService.markDirty(player)
	Economy.addCoins(player, totalValue, totalCount .. " fish sold")
end

function FishingService.init(remoteMap, hourGetter, anchors)
	remotes = remoteMap
	getHour = hourGetter
	remotes.events.CastLine.OnServerEvent:Connect(onCastLine)
	remotes.events.ReelIn.OnServerEvent:Connect(onReelIn)
	remotes.events.SellFish.OnServerEvent:Connect(onSellFish)
	-- World prompts: cast at the railed spots, sell at the market stall.
	local BK = require(script.Parent.BuildKit)
	if anchors then
		for idx, marker in ipairs(anchors.fishingAnchors) do
			BK.prompt(marker, "Cast line", "Fishing spot", function(player)
				onCastLine(player, idx)
			end, 0, 12)
		end
		BK.prompt(anchors.marketCounter, "Sell your fish", "Fish Market", function(player)
			onSellFish(player)
		end, 0.4, 12)
	end
	Players.PlayerRemoving:Connect(function(player)
		casts[player] = nil
	end)
end

return FishingService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0010">
<Properties>
<string name="Name">HousingService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — HousingService
	Claimable cottages: claim/unclaim via the porch sign, repaint from the
	house panel, lock the door (a gentle force field only the owner passes).
	Claims are per-session (a cottage frees up when its owner leaves); your
	paint choice persists between visits.
]]

local Players = game:GetService("Players")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local Monetization = require(ReplicatedStorage.Shared.Monetization)
local DataService = require(script.Parent.DataService)
local MonetizationService = require(script.Parent.MonetizationService)
local BK = require(script.Parent.BuildKit)

local HousingService = {}

local remotes = nil
local anchors = nil
local owners = {}     -- cottageIndex -&gt; player
local ownedBy = {}    -- player -&gt; cottageIndex
local doorFields = {} -- cottageIndex -&gt; invisible door part (lock)

local function paletteFor(player, paletteId)
	for _, p in ipairs(Config.PaintPalettes) do
		if p.id == paletteId then return p end
	end
	if MonetizationService.ownsPass(player, "deluxe_home") then
		for _, p in ipairs(Monetization.PremiumPalettes) do
			if p.id == paletteId then return p end
		end
	end
	return nil
end

local function applyPaint(cottageIndex, palette)
	local a = anchors.cottages[cottageIndex]
	if not a then return end
	for _, part in ipairs(a.model:GetDescendants()) do
		if part:IsA("BasePart") then
			if part.Name == "BackWall" or part.Name == "SideWall" or part.Name == "FrontWall" or part.Name == "DoorHeader" then
				part.Color = palette.wall
			elseif part.Name == "Trim" then
				part.Color = palette.trim
			end
		end
	end
end

local function updateSign(cottageIndex)
	local a = anchors.cottages[cottageIndex]
	if not a then return end
	local sign = a.claimSign
	local old = sign:FindFirstChild("Label")
	if old then old:Destroy() end
	local owner = owners[cottageIndex]
	if owner then
		BK.billboard(sign, "🏠 " .. a.def.name .. "\n" .. owner.DisplayName .. "'s place", Color3.fromRGB(255, 235, 170), 4, 70)
	else
		BK.billboard(sign, a.def.name .. "\n(hold to claim)", Color3.fromRGB(210, 230, 210), 4, 70)
	end
	local prompt = sign:FindFirstChildOfClass("ProximityPrompt")
	if prompt then
		prompt.ActionText = owner and (owner.DisplayName .. "'s home") or "Claim this cottage"
		prompt.Enabled = (owner == nil)
	end
end

local function setLocked(cottageIndex, locked, owner)
	local existing = doorFields[cottageIndex]
	if existing then
		existing:Destroy()
		doorFields[cottageIndex] = nil
	end
	if not locked then return end
	local a = anchors.cottages[cottageIndex]
	local d = a.def.size[3]
	local door = BK.part({
		Parent = a.model, Name = "DoorField",
		Size = Vector3.new(6, 7.5, 1),
		CFrame = a.base * CFrame.new(0, 3.75, -d / 2 + 0.5),
		Color = Color3.fromRGB(150, 200, 255), Material = Enum.Material.ForceField,
	})
	door.Transparency = 0.6
	doorFields[cottageIndex] = door
	-- The owner can always walk through their own door.
	local ownerChar = owner and owner.Character
	if ownerChar then
		door.Touched:Connect(function() end) -- keep TouchInterest alive
	end
	door.CanCollide = true
	-- Simple owner passthrough: watch for the owner near the door and phase it.
	task.spawn(function()
		while door.Parent do
			local char = owner and owner.Parent and owner.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if hrp and (hrp.Position - door.Position).Magnitude &lt; 8 then
				door.CanCollide = false
				door.Transparency = 0.85
			else
				door.CanCollide = true
				door.Transparency = 0.6
			end
			task.wait(0.25)
		end
	end)
end

local function release(player, silent)
	local idx = ownedBy[player]
	if not idx then return end
	owners[idx] = nil
	ownedBy[player] = nil
	setLocked(idx, false, nil)
	updateSign(idx)
	if not silent then
		remotes.events.Toast:FireClient(player, "Cottage unclaimed.", "info")
	end
end

local function onClaim(player, cottageIndex)
	if type(cottageIndex) ~= "number" then return end
	local a = anchors.cottages[cottageIndex]
	if not a then return end
	if owners[cottageIndex] then
		remotes.events.Toast:FireClient(player, "Someone already lives there!", "warn")
		return
	end
	-- Proximity check against the claim sign
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp or (hrp.Position - a.claimSign.Position).Magnitude &gt; Config.MaxInteractDistance + 6 then
		return
	end
	release(player, true) -- moving house frees the old one
	owners[cottageIndex] = player
	ownedBy[player] = cottageIndex
	updateSign(cottageIndex)
	local data = DataService.get(player)
	local palette = paletteFor(player, data and data.cottagePaint or "seafoam") or Config.PaintPalettes[1]
	applyPaint(cottageIndex, palette)
	-- Deluxe pass flair: golden mailbox + porch lantern
	if MonetizationService.ownsPass(player, "deluxe_home") then
		a.mailbox.Color = Color3.fromRGB(212, 175, 55)
		a.mailbox.Material = Enum.Material.Metal
		if not a.model:FindFirstChild("PorchLantern") then
			local lantern = BK.part({ Parent = a.model, Name = "PorchLantern",
				Size = Vector3.new(0.9, 1.3, 0.9), Color = Color3.fromRGB(255, 226, 160),
				Material = Enum.Material.Neon,
				CFrame = a.base * CFrame.new(3.4, 6.4, -a.def.size[3] / 2 - 0.8), CanCollide = false })
			local l = BK.light(lantern, Color3.fromRGB(255, 214, 140), 16, 1.3)
			l.Enabled = true
			BK.tag(lantern, "NightLamp")
		end
	end
	remotes.events.Toast:FireClient(player, "🏠 Welcome home — " .. a.def.name .. " is yours!", "coins")
end

local function onPaint(player, paletteId)
	if type(paletteId) ~= "string" then return end
	local idx = ownedBy[player]
	if not idx then
		remotes.events.Toast:FireClient(player, "Claim a cottage first!", "warn")
		return
	end
	local palette = paletteFor(player, paletteId)
	if not palette then
		remotes.events.Toast:FireClient(player, "That palette needs the Deluxe Cottage pass.", "warn")
		return
	end
	local data = DataService.get(player)
	if data then
		data.cottagePaint = paletteId
		DataService.markDirty(player)
	end
	applyPaint(idx, palette)
	remotes.events.Toast:FireClient(player, "🎨 Repainted in " .. palette.label .. ".", "info")
end

local function onToggleLock(player)
	local idx = ownedBy[player]
	if not idx then return end
	local locked = doorFields[idx] == nil
	setLocked(idx, locked, player)
	remotes.events.Toast:FireClient(player, locked and "🔒 Door locked (you can still walk in)." or "🔓 Door unlocked.", "info")
end

function HousingService.ownedCottage(player)
	return ownedBy[player]
end

function HousingService.init(remoteMap, mapAnchors)
	remotes = remoteMap
	anchors = mapAnchors
	-- Claim prompts on every cottage sign
	for i, a in ipairs(anchors.cottages) do
		BK.prompt(a.claimSign, "Claim this cottage", a.def.name, function(player)
			onClaim(player, i)
		end, 0.8, 12)
		updateSign(i)
	end
	remotes.events.ClaimCottage.OnServerEvent:Connect(function(player, idx)
		if idx == nil then
			release(player, false)
		else
			onClaim(player, idx)
		end
	end)
	remotes.events.PaintCottage.OnServerEvent:Connect(onPaint)
	remotes.events.ToggleLock.OnServerEvent:Connect(onToggleLock)
	Players.PlayerRemoving:Connect(function(player)
		release(player, true)
	end)
end

return HousingService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0011">
<Properties>
<string name="Name">JobService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — JobService
	Three jobs, each a small server-validated loop:
	  Barista: brew at the machine -&gt; deliver to the glowing table.
	  Baker:   knead at the counter -&gt; bake in the oven -&gt; stock the shelf.
	  Courier: collect a letter at Town Hall -&gt; deliver to a cottage mailbox.
	Pay comes with a streak bonus, and VIP doubles everything.
]]

local Players = game:GetService("Players")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local Catalog = require(ReplicatedStorage.Shared.Catalog)
local MapData = require(ReplicatedStorage.Shared.MapData)
local DataService = require(script.Parent.DataService)
local Economy = require(script.Parent.Economy)
local MonetizationService = require(script.Parent.MonetizationService)

local JobService = {}

local remotes = nil
local anchors = nil -- map anchors from MapBuilder
local jobs = {}     -- player -&gt; { jobId, stage, targetIndex, sinceStage }
local highlights = {} -- player -&gt; Highlight instance (cleaned up on stage change)

local function clearHighlight(player)
	local h = highlights[player]
	if h then
		h:Destroy()
		highlights[player] = nil
	end
end

local function highlightPart(player, part)
	clearHighlight(player)
	local h = Instance.new("Highlight")
	h.FillColor = Color3.fromRGB(120, 220, 160)
	h.FillTransparency = 0.65
	h.OutlineColor = Color3.fromRGB(120, 220, 160)
	h.Adornee = part
	-- Parented under the player's own PlayerGui so only THEY see their
	-- objective glowing (a Highlight in the world replicates to everyone).
	local pg = player:FindFirstChild("PlayerGui")
	h.Parent = pg or part
	highlights[player] = h
end

local function near(player, part, extraRange)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp or not part then return false end
	local range = Config.MaxInteractDistance + (extraRange or 0)
	return (hrp.Position - part.Position).Magnitude &lt;= range
end

local function pay(player, base, what)
	local data = DataService.get(player)
	if not data then return end
	local mult = MonetizationService.payMultiplier(player)
	local amount = base * mult
	data.tasksCompleted = data.tasksCompleted + 1
	local streakNote = nil
	if data.tasksCompleted % Config.Jobs.StreakBonusEvery == 0 then
		amount = amount + Config.Jobs.StreakBonusCoins * mult
		streakNote = " (streak bonus!)"
	end
	DataService.markDirty(player)
	Economy.addCoins(player, amount, what .. (streakNote or "") .. (mult &gt; 1 and " ⭐VIP x2" or ""))
end

local function sendState(player)
	local j = jobs[player]
	if not j then
		remotes.events.JobState:FireClient(player, "none", {})
		return
	end
	remotes.events.JobState:FireClient(player, "task", {
		jobId = j.jobId, stage = j.stage, targetIndex = j.targetIndex,
		targetName = j.targetName,
	})
end

-- STAGE MACHINES -----------------------------------------------------------------

local function startBaristaOrder(player)
	local j = jobs[player]
	j.stage = "brew"
	highlightPart(player, anchors.shops.cafe.machine)
	j.targetName = "Brew the order at the espresso machine"
	sendState(player)
end

local function startBakerLoaf(player)
	local j = jobs[player]
	j.stage = "knead"
	highlightPart(player, anchors.shops.bakery.counter)
	j.targetName = "Knead dough at the counter"
	sendState(player)
end

local function startCourierLetter(player)
	local j = jobs[player]
	j.stage = "collect"
	highlightPart(player, anchors.townHall.desk)
	j.targetName = "Collect a letter at the Town Hall post desk"
	sendState(player)
end

local START_BY_JOB = {
	barista = startBaristaOrder,
	baker = startBakerLoaf,
	courier = startCourierLetter,
}

local function onTakeJob(player, jobId)
	if jobId ~= nil and type(jobId) ~= "string" then return end
	clearHighlight(player)
	if jobId == nil then
		jobs[player] = nil
		remotes.events.Toast:FireClient(player, "You're off the clock.", "info")
		sendState(player)
		return
	end
	local def = Catalog.JobById[jobId]
	if not def then return end
	jobs[player] = { jobId = jobId }
	remotes.events.Toast:FireClient(player, def.icon .. " You're the " .. def.name .. " now — " .. def.place .. "!", "info")
	START_BY_JOB[jobId](player)
end

-- Each JobAction click advances the current stage if the player is at the right prop.
local function onJobAction(player)
	local j = jobs[player]
	if not j then return end

	if j.jobId == "barista" then
		if j.stage == "brew" and near(player, anchors.shops.cafe.machine) then
			j.stage = "brewing"
			sendState(player)
			task.delay(Config.Jobs.Barista.BrewSeconds, function()
				local jj = jobs[player]
				if jj and jj.jobId == "barista" and jj.stage == "brewing" then
					jj.stage = "deliver"
					jj.targetIndex = math.random(1, #anchors.shops.cafe.tables)
					jj.targetName = "Deliver to the glowing table"
					highlightPart(player, anchors.shops.cafe.tables[jj.targetIndex])
					sendState(player)
				end
			end)
		elseif j.stage == "deliver" and near(player, anchors.shops.cafe.tables[j.targetIndex or 1]) then
			pay(player, Config.Jobs.Barista.PayPerOrder, "order served")
			startBaristaOrder(player)
		end

	elseif j.jobId == "baker" then
		if j.stage == "knead" and near(player, anchors.shops.bakery.counter) then
			j.stage = "kneading"
			sendState(player)
			task.delay(Config.Jobs.Baker.KneadSeconds, function()
				local jj = jobs[player]
				if jj and jj.jobId == "baker" and jj.stage == "kneading" then
					jj.stage = "bake"
					jj.targetName = "Bake it in the oven"
					highlightPart(player, anchors.shops.bakery.oven)
					sendState(player)
				end
			end)
		elseif j.stage == "bake" and near(player, anchors.shops.bakery.oven) then
			j.stage = "baking"
			sendState(player)
			task.delay(Config.Jobs.Baker.BakeSeconds, function()
				local jj = jobs[player]
				if jj and jj.jobId == "baker" and jj.stage == "baking" then
					jj.stage = "stock"
					jj.targetName = "Stock the bread shelf"
					highlightPart(player, anchors.shops.bakery.shelf)
					sendState(player)
				end
			end)
		elseif j.stage == "stock" and near(player, anchors.shops.bakery.shelf) then
			pay(player, Config.Jobs.Baker.PayPerLoaf, "fresh loaf stocked")
			startBakerLoaf(player)
		end

	elseif j.jobId == "courier" then
		if j.stage == "collect" and near(player, anchors.townHall.desk) then
			j.stage = "deliver"
			j.targetIndex = math.random(1, #anchors.cottages)
			local cottage = anchors.cottages[j.targetIndex]
			j.targetName = "Deliver to the mailbox at " .. cottage.def.name
			highlightPart(player, cottage.mailbox)
			sendState(player)
			remotes.events.Toast:FireClient(player, "✉️ Letter for " .. cottage.def.name .. "!", "info")
		elseif j.stage == "deliver" and near(player, anchors.cottages[j.targetIndex or 1].mailbox, 4) then
			pay(player, Config.Jobs.Courier.PayPerDelivery, "letter delivered")
			startCourierLetter(player)
		end
	end
end

function JobService.currentJob(player)
	local j = jobs[player]
	return j and j.jobId or nil
end

function JobService.init(remoteMap, mapAnchors)
	remotes = remoteMap
	anchors = mapAnchors
	remotes.events.TakeJob.OnServerEvent:Connect(onTakeJob)
	remotes.events.JobAction.OnServerEvent:Connect(onJobAction)

	-- World prompts on every job prop; the stage machine sorts out what
	-- (if anything) each press means for that player right now.
	local BK = require(script.Parent.BuildKit)
	local props = {
		{ anchors.shops.cafe.machine, "Brew", "Espresso machine" },
		{ anchors.shops.bakery.counter, "Knead", "Baker's counter" },
		{ anchors.shops.bakery.oven, "Bake", "Oven" },
		{ anchors.shops.bakery.shelf, "Stock", "Bread shelf" },
		{ anchors.townHall.desk, "Collect letters", "Post desk" },
	}
	for _, entry in ipairs(props) do
		BK.prompt(entry[1], entry[2], entry[3], function(player)
			onJobAction(player)
		end, 0.3, 10)
	end
	for _, tbl in ipairs(anchors.shops.cafe.tables) do
		BK.prompt(tbl, "Serve", "Cafe table", function(player)
			onJobAction(player)
		end, 0.2, 8)
	end
	-- Courier deliveries: every cottage mailbox is a drop-off point.
	for _, cottage in ipairs(anchors.cottages) do
		BK.prompt(cottage.mailbox, "Deliver letter", "Mailbox", function(player)
			onJobAction(player)
		end, 0.3, 10)
	end
	-- The notice board opens the Jobs panel client-side.
	BK.prompt(anchors.square.noticeBoard, "Browse jobs", "Notice Board", function(player)
		remotes.events.OpenUI:FireClient(player, "jobs")
	end, 0, 12)

	Players.PlayerRemoving:Connect(function(player)
		clearHighlight(player)
		jobs[player] = nil
	end)
end

return JobService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0012">
<Properties>
<string name="Name">MapBuilder</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — MapBuilder
	Orchestrates world generation: terrain, plaza, paths, buildings, park,
	boardwalk/pier/lighthouse, cottages, lamps, and nature. Returns a table of
	anchors ("the espresso machine", "cottage 3's mailbox") that gameplay
	systems wire behavior onto.
]]

local Workspace = game:GetService("Workspace")

local BK = require(script.Parent.BuildKit)
local Buildings = require(script.Parent.Buildings)
local MapData = require(game:GetService("ReplicatedStorage").Shared.MapData)

local MapBuilder = {}

local function buildTerrain()
	local terrain = Workspace.Terrain
	for _, fill in ipairs(MapData.Terrain) do
		local c, s = fill.cframe, fill.size
		terrain:FillBlock(
			CFrame.new(c[1], c[2], c[3]),
			Vector3.new(s[1], s[2], s[3]),
			Enum.Material[fill.material]
		)
	end
end

-- NOTE: the SpawnLocation ships inside the place file itself (see build.py)
-- so players have somewhere to stand even if a script error stops the build.

local function buildSquare(root)
	local m = BK.model("TownSquare", root)
	local sq = MapData.Square
	BK.part({ Parent = m, Name = "Plaza", Size = Vector3.new(sq.size[1], 0.5, sq.size[2]),
		Color = Color3.fromRGB(196, 186, 164), Material = Enum.Material.Cobblestone,
		CFrame = BK.cfOnGround(sq.center[1], sq.center[2], 0.5, 0) })

	-- Fountain: basin ring, water disc, spire with drifting mist
	local f = MapData.fountain or sq.fountain
	local fx, fz = f[1], f[2]
	local basin = BK.cylinder({ Parent = m, Name = "FountainBasin", Size = Vector3.new(1.6, 16, 16),
		Color = Color3.fromRGB(170, 168, 160), Material = Enum.Material.Slate,
		CFrame = CFrame.new(fx, 1.0, fz) * CFrame.Angles(0, 0, math.rad(90)) })
	local water = BK.cylinder({ Parent = m, Name = "FountainWater", Size = Vector3.new(0.5, 13.5, 13.5),
		Color = Color3.fromRGB(120, 190, 215), Material = Enum.Material.Glass,
		CFrame = CFrame.new(fx, 1.45, fz) * CFrame.Angles(0, 0, math.rad(90)), CanCollide = true })
	water.Transparency = 0.35
	BK.cylinder({ Parent = m, Name = "FountainSpire", Size = Vector3.new(6, 2.4, 2.4),
		Color = Color3.fromRGB(170, 168, 160), Material = Enum.Material.Slate,
		CFrame = CFrame.new(fx, 3.2, fz) * CFrame.Angles(0, 0, math.rad(90)) })
	local jet = BK.ball({ Parent = m, Name = "FountainJet", Size = Vector3.new(1.6, 1.6, 1.6),
		Color = Color3.fromRGB(200, 235, 245), Material = Enum.Material.Neon, CanCollide = false,
		CFrame = CFrame.new(fx, 6.6, fz) })
	jet.Transparency = 0.25
	local mist = Instance.new("ParticleEmitter")
	-- (keep the default particle texture — clearing it renders blank quads)
	mist.Rate = 6
	mist.Lifetime = NumberRange.new(1.2, 2.0)
	mist.Speed = NumberRange.new(1.5, 3)
	mist.SpreadAngle = Vector2.new(25, 25)
	mist.Color = ColorSequence.new(Color3.fromRGB(205, 235, 245))
	mist.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.6),
		NumberSequenceKeypoint.new(1, 1),
	})
	mist.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.8),
		NumberSequenceKeypoint.new(1, 2.4),
	})
	mist.Parent = jet

	-- Notice board (jobs)
	local nb = MapData.Square.noticeBoard
	local post = BK.part({ Parent = m, Name = "NoticePost", Size = Vector3.new(0.8, 7, 0.8),
		Color = Color3.fromRGB(96, 76, 58), Material = Enum.Material.Wood,
		CFrame = BK.cfOnGround(nb[1], nb[2], 7, 0) })
	local board = BK.part({ Parent = m, Name = "NoticeBoard", Size = Vector3.new(8, 4.6, 0.7),
		Color = Color3.fromRGB(120, 94, 68), Material = Enum.Material.Wood,
		CFrame = post.CFrame * CFrame.new(0, 1.2, 0) })
	BK.faceText(board, Enum.NormalId.Back, "NOTICE BOARD\nJOBS POSTED DAILY", Color3.fromRGB(245, 235, 210), 0.16)
	BK.faceText(board, Enum.NormalId.Front, "NOTICE BOARD\nJOBS POSTED DAILY", Color3.fromRGB(245, 235, 210), 0.16)
	return { noticeBoard = board }
end

local function buildPaths(root)
	local m = BK.model("Paths", root)
	for _, p in ipairs(MapData.Paths) do
		BK.part({ Parent = m, Name = "Path", Size = Vector3.new(p[3], 0.35, p[4]),
			Color = Color3.fromRGB(186, 176, 154), Material = Enum.Material.Cobblestone,
			CFrame = BK.cfOnGround(p[1], p[2], 0.35, p[5]) })
	end
end

local function buildPark(root)
	local m = BK.model("Park", root)
	local park = MapData.Park

	-- Campfire: stone ring, logs, fire glow + particles, sitting logs around it
	local cf = park.campfire
	local fire = BK.model("Campfire", m)
	for i = 1, 8 do
		local a = (i / 8) * math.pi * 2
		BK.part({ Parent = fire, Name = "FireStone", Size = Vector3.new(1.4, 1.1, 1.4),
			Color = Color3.fromRGB(120, 118, 112), Material = Enum.Material.Rock,
			CFrame = CFrame.new(cf[1] + math.cos(a) * 3, 0.55, cf[2] + math.sin(a) * 3) * CFrame.Angles(0, a, 0) })
	end
	local flame = BK.part({ Parent = fire, Name = "Flame", Size = Vector3.new(1.8, 1.6, 1.8),
		Color = Color3.fromRGB(255, 150, 60), Material = Enum.Material.Neon, CanCollide = false,
		CFrame = CFrame.new(cf[1], 1.2, cf[2]) })
	flame.Transparency = 0.15
	local fireLight = BK.light(flame, Color3.fromRGB(255, 160, 80), 24, 2)
	fireLight.Enabled = true
	local ember = Instance.new("ParticleEmitter")
	ember.Rate = 10
	ember.Lifetime = NumberRange.new(0.8, 1.6)
	ember.Speed = NumberRange.new(3, 6)
	ember.SpreadAngle = Vector2.new(12, 12)
	ember.Color = ColorSequence.new(Color3.fromRGB(255, 170, 70), Color3.fromRGB(255, 90, 40))
	ember.LightEmission = 1
	ember.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.5),
		NumberSequenceKeypoint.new(1, 0.1),
	})
	ember.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.2),
		NumberSequenceKeypoint.new(1, 1),
	})
	ember.Parent = flame
	for i = 1, 4 do
		local a = (i / 4) * math.pi * 2 + math.pi / 4
		local seat = Instance.new("Seat")
		seat.Anchored = true
		seat.Size = Vector3.new(4.6, 1.4, 1.8)
		seat.Color = Color3.fromRGB(110, 86, 62)
		seat.Material = Enum.Material.Wood
		seat.CFrame = CFrame.new(cf[1] + math.cos(a) * 7.5, 0.7, cf[2] + math.sin(a) * 7.5) *
			CFrame.Angles(0, -a + math.pi / 2, 0)
		seat.Parent = fire
	end

	-- Benches
	for _, b in ipairs(park.benches) do
		local bench = Instance.new("Seat")
		bench.Anchored = true
		bench.Size = Vector3.new(6.5, 1, 2.2)
		bench.Color = Color3.fromRGB(124, 98, 70)
		bench.Material = Enum.Material.Wood
		bench.CFrame = BK.cfOnGround(b[1], b[2], 2, b[3])
		bench.Parent = m
		BK.part({ Parent = m, Name = "BenchBack", Size = Vector3.new(6.5, 2.2, 0.6),
			Color = Color3.fromRGB(116, 90, 64), Material = Enum.Material.Wood,
			CFrame = bench.CFrame * CFrame.new(0, 1.2, 1.1) })
	end

	-- Wren's easel
	local e = park.easel
	local easel = BK.model("Easel", m)
	for i = -1, 1, 2 do
		BK.part({ Parent = easel, Name = "EaselLeg", Size = Vector3.new(0.4, 5.5, 0.4),
			Color = Color3.fromRGB(140, 110, 80), Material = Enum.Material.Wood,
			CFrame = CFrame.new(e[1] + i * 1.1, 2.75, e[2]) * CFrame.Angles(0, 0, math.rad(i * 8)) })
	end
	local canvas = BK.part({ Parent = easel, Name = "Canvas", Size = Vector3.new(3.4, 2.8, 0.2),
		Color = Color3.fromRGB(250, 248, 240), Material = Enum.Material.SmoothPlastic,
		CFrame = CFrame.new(e[1], 3.4, e[2]) * CFrame.Angles(math.rad(-8), 0, 0) })
	BK.faceText(canvas, Enum.NormalId.Front, "🌊⛯", nil, 0.2)
end

local function buildBoardwalkAndPier(root)
	local m = BK.model("Waterfront", root)
	local bw = MapData.Boardwalk

	-- Boardwalk deck on posts
	BK.part({ Parent = m, Name = "BoardwalkDeck", Size = Vector3.new(bw.size[1], 1, bw.size[2]),
		Color = Color3.fromRGB(158, 128, 96), Material = Enum.Material.WoodPlanks,
		CFrame = CFrame.new(bw.center[1], bw.deckY, bw.center[2]) })
	for x = -bw.size[1] / 2 + 10, bw.size[1] / 2 - 10, 20 do
		BK.part({ Parent = m, Name = "DeckPost", Size = Vector3.new(1.2, 4, 1.2),
			Color = Color3.fromRGB(120, 96, 72), Material = Enum.Material.Wood,
			CFrame = CFrame.new(bw.center[1] + x, -0.5, bw.center[2] + bw.size[2] / 2 - 1) })
	end
	-- Ramp up from the sand side (wedge's tall face points at the deck, +Z)
	BK.wedge({ Parent = m, Name = "BoardwalkRamp", Size = Vector3.new(16, 1.6, 4),
		Color = Color3.fromRGB(150, 122, 92), Material = Enum.Material.WoodPlanks,
		CFrame = CFrame.new(bw.center[1], 0.8, bw.center[2] - bw.size[2] / 2 - 2) })

	-- Pier
	local pier = MapData.Pier
	local pierLen = pier.zEnd - pier.zStart
	BK.part({ Parent = m, Name = "PierDeck", Size = Vector3.new(pier.width, 1, pierLen),
		Color = Color3.fromRGB(150, 120, 90), Material = Enum.Material.WoodPlanks,
		CFrame = CFrame.new(pier.x, bw.deckY, pier.zStart + pierLen / 2) })
	for z = pier.zStart + 8, pier.zEnd - 4, 14 do
		for i = -1, 1, 2 do
			BK.part({ Parent = m, Name = "PierPost", Size = Vector3.new(1.2, 8, 1.2),
				Color = Color3.fromRGB(110, 88, 66), Material = Enum.Material.Wood,
				CFrame = CFrame.new(pier.x + i * (pier.width / 2 - 0.6), -2, z) })
			BK.part({ Parent = m, Name = "PierRail", Size = Vector3.new(0.5, 0.5, 14),
				Color = Color3.fromRGB(126, 100, 76), Material = Enum.Material.Wood,
				CFrame = CFrame.new(pier.x + i * (pier.width / 2 - 0.6), 4.4, z) })
		end
	end

	-- Fishing spots: little rail markers with prompts wired later by FishingService
	local fishingAnchors = {}
	for idx, fsp in ipairs(MapData.FishingSpots) do
		local marker = BK.part({ Parent = m, Name = "FishingSpot" .. idx, Size = Vector3.new(2.4, 1.1, 0.8),
			Color = Color3.fromRGB(90, 140, 170), Material = Enum.Material.Wood,
			CFrame = BK.cfOnGround(fsp[1], fsp[2], 1.1 + MapData.Boardwalk.deckY * 2, fsp[3]) })
		BK.billboard(marker, "🎣", nil, 2.4, 60)
		fishingAnchors[#fishingAnchors + 1] = marker
	end

	-- Market stall (sell fish) and ice cream stand
	local function stall(def, topColor, name)
		local sm = BK.model(name, m)
		local base = CFrame.new(def.x, MapData.Boardwalk.deckY + 0.5, def.z) * CFrame.Angles(0, math.rad(def.facing or 0), 0)
		local counter = BK.part({ Parent = sm, Name = name .. "Counter", Size = Vector3.new(8, 3, 2.6),
			Color = Color3.fromRGB(120, 94, 68), Material = Enum.Material.Wood, CFrame = base * CFrame.new(0, 1.5, 0) })
		for i = -1, 1, 2 do
			BK.part({ Parent = sm, Name = "StallPost", Size = Vector3.new(0.6, 7, 0.6),
				Color = Color3.fromRGB(110, 88, 66), Material = Enum.Material.Wood,
				CFrame = base * CFrame.new(i * 3.7, 3.5, 0.8) })
		end
		local canopy = BK.part({ Parent = sm, Name = "StallCanopy", Size = Vector3.new(9, 0.5, 5),
			Color = topColor, Material = Enum.Material.Fabric, CFrame = base * CFrame.new(0, 7.2, 0.4) * CFrame.Angles(math.rad(-8), 0, 0) })
		BK.faceText(BK.part({ Parent = sm, Name = "StallSign", Size = Vector3.new(7, 1.3, 0.4),
			Color = Color3.fromRGB(60, 46, 36), Material = Enum.Material.Wood,
			CFrame = base * CFrame.new(0, 5.4, -1.2), CanCollide = false }), Enum.NormalId.Front, def.sign)
		return counter
	end
	local marketCounter = stall(MapData.MarketStall, Color3.fromRGB(80, 130, 170), "FishMarket")
	local scoopsCounter = stall(MapData.IceCreamStand, Color3.fromRGB(240, 170, 190), "Scoops")

	return { fishingAnchors = fishingAnchors, marketCounter = marketCounter, scoopsCounter = scoopsCounter }
end

local function buildLighthouse(root)
	local m = BK.model("Lighthouse", root)
	local lh = MapData.Lighthouse
	local x, z = lh.pos[1], lh.pos[2]
	local baseY = lh.baseY

	-- Walkway from the boardwalk to the headland, then a few steps up
	local wk = lh.walkway
	local wlen = wk.toX - wk.fromX
	BK.part({ Parent = m, Name = "Walkway", Size = Vector3.new(wlen, 1, 8),
		Color = Color3.fromRGB(150, 120, 90), Material = Enum.Material.WoodPlanks,
		CFrame = CFrame.new(wk.fromX + wlen / 2, wk.y, wk.z) })
	-- Stone stairway from the walkway end up onto the rock: nine chunky steps
	-- marching south along z, each rising 0.4 so walking up needs no jumps,
	-- landing flush with the headland path (top ~5.1).
	for i = 1, 9 do
		BK.part({ Parent = m, Name = "Step", Size = Vector3.new(6, 1, 3.6),
			Color = Color3.fromRGB(150, 148, 140), Material = Enum.Material.Rock,
			CFrame = CFrame.new(wk.toX + 6, wk.y - 0.2 + i * 0.4, wk.z + 1.5 + i * 4) })
	end
	BK.part({ Parent = m, Name = "HeadlandPath", Size = Vector3.new(10, 0.6, 26),
		Color = Color3.fromRGB(158, 156, 148), Material = Enum.Material.Rock,
		CFrame = CFrame.new(x - 4, baseY + 0.3, z - 18) * CFrame.Angles(0, math.rad(12), 0) })

	-- Tower: stacked red/white bands
	local bands = 5
	local bandH = lh.height / bands
	for i = 1, bands do
		local isRed = (i % 2 == 1)
		BK.cylinder({ Parent = m, Name = "TowerBand", Size = Vector3.new(bandH, lh.radius * 2 * (1 - i * 0.04), lh.radius * 2 * (1 - i * 0.04)),
			Color = isRed and Color3.fromRGB(190, 60, 55) or Color3.fromRGB(245, 242, 235),
			Material = Enum.Material.Concrete,
			CFrame = CFrame.new(x, baseY + bandH * (i - 0.5), z) * CFrame.Angles(0, 0, math.rad(90)) })
	end
	-- Gallery + lamp room
	local topY = baseY + lh.height
	BK.cylinder({ Parent = m, Name = "Gallery", Size = Vector3.new(1.2, lh.radius * 2 + 3, lh.radius * 2 + 3),
		Color = Color3.fromRGB(50, 54, 60), Material = Enum.Material.Metal,
		CFrame = CFrame.new(x, topY + 0.6, z) * CFrame.Angles(0, 0, math.rad(90)) })
	local lampRoom = BK.part({ Parent = m, Name = "LampRoom", Size = Vector3.new(6, 5, 6),
		Color = Color3.fromRGB(200, 225, 235), Material = Enum.Material.Glass,
		CFrame = CFrame.new(x, topY + 3.7, z) })
	lampRoom.Transparency = 0.45
	local lampCore = BK.ball({ Parent = m, Name = "LampCore", Size = Vector3.new(3, 3, 3),
		Color = Color3.fromRGB(255, 235, 170), Material = Enum.Material.Neon,
		CFrame = CFrame.new(x, topY + 3.7, z), CanCollide = false })
	BK.cylinder({ Parent = m, Name = "LampRoof", Size = Vector3.new(1.6, 8, 8),
		Color = Color3.fromRGB(160, 55, 50), Material = Enum.Material.Metal,
		CFrame = CFrame.new(x, topY + 6.8, z) * CFrame.Angles(0, 0, math.rad(90)) })

	-- The rotating beam: a long translucent neon prism parented to a pivot part.
	-- DayNight spins the pivot and toggles visibility.
	local pivot = BK.part({ Parent = m, Name = "BeamPivot", Size = Vector3.new(0.5, 0.5, 0.5),
		Color = Color3.fromRGB(255, 255, 255), Material = Enum.Material.Neon, CanCollide = false,
		CFrame = CFrame.new(x, topY + 3.7, z) })
	pivot.Transparency = 1
	local beam = BK.part({ Parent = m, Name = "BeamRay", Size = Vector3.new(1.6, 1.6, 90),
		Color = Color3.fromRGB(255, 240, 190), Material = Enum.Material.Neon, CanCollide = false,
		CFrame = pivot.CFrame * CFrame.new(0, 0, -48) })
	beam.Transparency = 1 -- hidden by day; DayNight fades it in at night
	beam.CastShadow = false
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = pivot
	weld.Part1 = beam
	weld.Parent = pivot
	-- NOTE: both parts stay Anchored; DayNight rotates `pivot.CFrame` directly
	-- and moves the welded beam by re-setting its offset each step. Cheap + robust.

	local lampLight = BK.light(lampCore, Color3.fromRGB(255, 240, 190), 60, 2.4)

	return { pivot = pivot, beam = beam, core = lampCore, light = lampLight, topCF = CFrame.new(x, topY + 3.7, z) }
end

local function buildFerry(root)
	local m = BK.model("Ferry", root)
	local dock = MapData.FerryDock

	-- Dock bumper
	BK.part({ Parent = m, Name = "DockBumper", Size = Vector3.new(3, 2.5, 10),
		Color = Color3.fromRGB(110, 88, 66), Material = Enum.Material.Wood,
		CFrame = CFrame.new(dock.x - 3, 0.4, dock.z) })

	-- The Pelican: hull + deck + benches + little cabin. PrimaryPart = hull.
	local boat = BK.model("ThePelican", m)
	local hull = BK.part({ Parent = boat, Name = "Hull", Size = Vector3.new(10, 3, 22),
		Color = Color3.fromRGB(70, 100, 140), Material = Enum.Material.SmoothPlastic,
		CFrame = CFrame.new(dock.x + 6, 0.2, dock.z) })
	BK.part({ Parent = boat, Name = "Deck", Size = Vector3.new(9.4, 0.6, 21),
		Color = Color3.fromRGB(168, 138, 104), Material = Enum.Material.WoodPlanks,
		CFrame = hull.CFrame * CFrame.new(0, 1.8, 0) })
	BK.wedge({ Parent = boat, Name = "Bow", Size = Vector3.new(10, 3, 6),
		Color = Color3.fromRGB(70, 100, 140), Material = Enum.Material.SmoothPlastic,
		CFrame = hull.CFrame * CFrame.new(0, 0, -14) })
	-- Rails
	for i = -1, 1, 2 do
		BK.part({ Parent = boat, Name = "Rail", Size = Vector3.new(0.5, 2.4, 21),
			Color = Color3.fromRGB(235, 235, 230), Material = Enum.Material.SmoothPlastic,
			CFrame = hull.CFrame * CFrame.new(i * 4.7, 3.2, 0) })
	end
	BK.part({ Parent = boat, Name = "SternRail", Size = Vector3.new(9.9, 2.4, 0.5),
		Color = Color3.fromRGB(235, 235, 230), Material = Enum.Material.SmoothPlastic,
		CFrame = hull.CFrame * CFrame.new(0, 3.2, 10.7) })
	-- Benches (6 rider seats)
	for row = -1, 1 do
		for i = -1, 1, 2 do
			local seat = Instance.new("Seat")
			seat.Anchored = true
			seat.Size = Vector3.new(3.4, 0.8, 2)
			seat.Color = Color3.fromRGB(150, 118, 86)
			seat.Material = Enum.Material.Wood
			seat.CFrame = hull.CFrame * CFrame.new(i * 2.6, 2.6, row * 5 + 2)
			seat.Name = "RiderSeat"
			seat.Parent = boat
		end
	end
	-- Cabin + smokestack
	BK.part({ Parent = boat, Name = "Cabin", Size = Vector3.new(6, 4, 5),
		Color = Color3.fromRGB(235, 230, 220), Material = Enum.Material.SmoothPlastic,
		CFrame = hull.CFrame * CFrame.new(0, 4, -7) })
	BK.cylinder({ Parent = boat, Name = "Stack", Size = Vector3.new(4, 1.6, 1.6),
		Color = Color3.fromRGB(60, 60, 65), Material = Enum.Material.Metal,
		CFrame = hull.CFrame * CFrame.new(1.8, 7.5, -6) * CFrame.Angles(0, 0, math.rad(90)) })
	local nameBoard = BK.part({ Parent = boat, Name = "NameBoard", Size = Vector3.new(5.5, 1.1, 0.4),
		Color = Color3.fromRGB(50, 42, 34), Material = Enum.Material.Wood,
		CFrame = hull.CFrame * CFrame.new(0, 3.4, 11.2), CanCollide = false })
	BK.faceText(nameBoard, Enum.NormalId.Back, "THE PELICAN", Color3.fromRGB(250, 240, 210))

	boat.PrimaryPart = hull
	return { boat = boat, hull = hull }
end

local function buildLampposts(root)
	local m = BK.model("Streetlamps", root)
	for i, pos in ipairs(MapData.Lamps) do
		local lamp = BK.model("Lamp" .. i, m)
		BK.part({ Parent = lamp, Name = "LampPole", Size = Vector3.new(0.7, 11, 0.7),
			Color = Color3.fromRGB(52, 56, 62), Material = Enum.Material.Metal,
			CFrame = BK.cfOnGround(pos[1], pos[2], 11, 0) })
		BK.part({ Parent = lamp, Name = "LampArm", Size = Vector3.new(0.5, 0.5, 2.6),
			Color = Color3.fromRGB(52, 56, 62), Material = Enum.Material.Metal,
			CFrame = CFrame.new(pos[1], 10.6, pos[2] + 1) })
		local head = BK.part({ Parent = lamp, Name = "LampHead", Size = Vector3.new(1.5, 1.2, 1.5),
			Color = Color3.fromRGB(255, 226, 160), Material = Enum.Material.Neon,
			CFrame = CFrame.new(pos[1], 10.0, pos[2] + 2), CanCollide = false })
		head.Transparency = 0.55 -- dimmed by day; DayNight brightens
		BK.light(head, Color3.fromRGB(255, 214, 140), 22, 1.6)
		BK.tag(head, "NightLamp")
	end
end

local function buildNature(root)
	local m = BK.model("Nature", root)
	for _, n in ipairs(MapData.Nature) do
		local s = n.scale
		if n.kind == "pine" then
			local tm = BK.model("Pine", m)
			BK.cylinder({ Parent = tm, Name = "Trunk", Size = Vector3.new(7 * s, 1.6 * s, 1.6 * s),
				Color = Color3.fromRGB(110, 82, 58), Material = Enum.Material.Wood,
				CFrame = CFrame.new(n.x, 3.5 * s, n.z) * CFrame.Angles(0, 0, math.rad(90)) })
			for layer = 1, 3 do
				local ly = 5 * s + layer * 2.6 * s
				local lw = (10 - layer * 2.4) * s
				BK.part({ Parent = tm, Name = "Canopy", Size = Vector3.new(lw, 2.6 * s, lw),
					Color = Color3.fromRGB(66, 112, 80), Material = Enum.Material.Grass,
					CFrame = CFrame.new(n.x, ly, n.z) * CFrame.Angles(0, math.rad(45 * layer), 0), CanCollide = false })
			end
		elseif n.kind == "oak" then
			local tm = BK.model("Oak", m)
			BK.cylinder({ Parent = tm, Name = "Trunk", Size = Vector3.new(6 * s, 2 * s, 2 * s),
				Color = Color3.fromRGB(120, 90, 62), Material = Enum.Material.Wood,
				CFrame = CFrame.new(n.x, 3 * s, n.z) * CFrame.Angles(0, 0, math.rad(90)) })
			local crown = BK.ball({ Parent = tm, Name = "Crown", Size = Vector3.new(11 * s, 8 * s, 11 * s),
				Color = Color3.fromRGB(84, 130, 88), Material = Enum.Material.Grass,
				CFrame = CFrame.new(n.x, 8.5 * s, n.z), CanCollide = false })
			crown.CastShadow = true
		elseif n.kind == "rock" then
			BK.part({ Parent = m, Name = "Rock", Size = Vector3.new(4.5 * s, 3 * s, 3.8 * s),
				Color = Color3.fromRGB(136, 134, 128), Material = Enum.Material.Rock,
				CFrame = CFrame.new(n.x, 1.2 * s, n.z) * CFrame.Angles(math.rad(8), math.rad(n.x * 7 % 360), math.rad(-6)) })
		elseif n.kind == "flowers" then
			local fm = BK.model("FlowerPatch", m)
			local palette = {
				Color3.fromRGB(240, 130, 150), Color3.fromRGB(250, 210, 100),
				Color3.fromRGB(160, 140, 230), Color3.fromRGB(250, 250, 245),
			}
			for k = 1, 5 do
				local a = k * 2.39996 -- golden angle scatter
				local r = 0.6 + k * 0.5
				BK.part({ Parent = fm, Name = "Flower", Size = Vector3.new(0.5, 0.9, 0.5),
					Color = palette[(k % #palette) + 1], Material = Enum.Material.Grass,
					CFrame = CFrame.new(n.x + math.cos(a) * r, 0.45, n.z + math.sin(a) * r), CanCollide = false })
			end
		end
	end
end

-- PUBLIC ---------------------------------------------------------------------

function MapBuilder.build()
	local root = BK.model("LanternsideBay", Workspace)
	local anchors = {}

	buildTerrain()
	anchors.square = buildSquare(root)
	buildPaths(root)
	buildPark(root)
	anchors.waterfront = buildBoardwalkAndPier(root)
	anchors.lighthouse = buildLighthouse(root)
	anchors.ferry = buildFerry(root)
	buildLampposts(root)
	buildNature(root)

	-- Shops + town hall
	anchors.shops = {}
	local Buildings_ = Buildings
	for _, def in ipairs(MapData.Shops) do
		local opts = {
			name = def.name, parent = root,
			pos = def.pos, size = def.size, facing = def.facing,
			wall = Color3.fromRGB(def.wall[1], def.wall[2], def.wall[3]),
			roof = Color3.fromRGB(def.roof[1], def.roof[2], def.roof[3]),
			sign = def.sign,
		}
		if def.kind == "cafe" then
			local model, a = Buildings_.buildCafe(opts)
			anchors.shops.cafe = a
		elseif def.kind == "bakery" then
			local model, a = Buildings_.buildBakery(opts)
			anchors.shops.bakery = a
		elseif def.kind == "store" then
			local model, a = Buildings_.buildStore(opts)
			anchors.shops.store = a
		end
	end
	do
		local th = MapData.TownHall
		local model, a = Buildings_.buildTownHall({
			name = th.name, parent = root,
			pos = th.pos, size = th.size, facing = th.facing,
			wall = Color3.fromRGB(th.wall[1], th.wall[2], th.wall[3]),
			roof = Color3.fromRGB(th.roof[1], th.roof[2], th.roof[3]),
			sign = th.sign,
		})
		anchors.townHall = a
	end

	-- Cottages
	anchors.cottages = {}
	for i, def in ipairs(MapData.Cottages) do
		local model, a = Buildings_.buildCottage({
			name = def.name, parent = root,
			pos = def.pos, size = def.size, facing = def.facing,
			wall = Color3.fromRGB(210, 200, 185), -- repainted on claim
			quilt = nil,
		})
		a.model = model
		a.def = def
		anchors.cottages[i] = a
	end

	return root, anchors
end

return MapBuilder
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0013">
<Properties>
<string name="Name">MonetizationService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — MonetizationService
	MarketplaceService wiring: purchase prompts, gamepass ownership (cached),
	and an idempotent ProcessReceipt for coin packs. Every benefit is granted
	server-side; owning a pass is re-checked from Roblox, never trusted from
	the client.
]]

local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Monetization = require(ReplicatedStorage.Shared.Monetization)
local DataService = require(script.Parent.DataService)
local Economy = require(script.Parent.Economy)

local MonetizationService = {}

local remotes = nil
local passCache = {} -- player -&gt; { passKey -&gt; bool }

-- Does this player own a pass? (cached per session; refreshed after purchase)
function MonetizationService.ownsPass(player, passKey)
	local def = Monetization.PassById[passKey]
	if not def or def.passId == 0 then return false end
	local cache = passCache[player]
	if cache and cache[passKey] ~= nil then
		return cache[passKey]
	end
	local owns = false
	local ok, result = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, def.passId)
	end)
	if ok then owns = result end
	passCache[player] = passCache[player] or {}
	passCache[player][passKey] = owns
	return owns
end

function MonetizationService.applyJoinBenefits(player)
	-- VIP: visit bonus (per join, deliberately generous — it advertises itself)
	if MonetizationService.ownsPass(player, "vip") then
		Economy.addCoins(player, Monetization.VIPJoinBonus, "VIP visit bonus")
	end
	-- Master Angler: ensure the Moonlit Rod is owned + offer equip
	if MonetizationService.ownsPass(player, "angler") then
		local data = DataService.get(player)
		if data and not data.ownedRods.moonlit then
			data.ownedRods.moonlit = true
			DataService.markDirty(player)
			if remotes then
				remotes.events.Toast:FireClient(player, "🎣 The Moonlit Rod is yours — equip it in the shop!", "info")
			end
		end
	end
	-- Emote pack + VIP emotes
	local data = DataService.get(player)
	if data then
		for _, e in ipairs(Monetization.PassEmotes) do
			if MonetizationService.ownsPass(player, e.pass) then
				data.ownedEmotes[e.id] = true
			end
		end
		DataService.markDirty(player)
	end
end

function MonetizationService.payMultiplier(player)
	if MonetizationService.ownsPass(player, "vip") then
		return Monetization.VIPPayMultiplier
	end
	return 1
end

-- Client asks to open a purchase prompt. We validate the id and forward to Roblox.
local function onPromptPurchase(player, kind, id)
	if type(id) ~= "string" then return end
	if kind == "product" then
		local def = Monetization.ProductById[id]
		if def and def.productId ~= 0 then
			pcall(function()
				MarketplaceService:PromptProductPurchase(player, def.productId)
			end)
		elseif remotes then
			remotes.events.Toast:FireClient(player, "This pack isn't set up yet — soon!", "info")
		end
	elseif kind == "pass" then
		local def = Monetization.PassById[id]
		if def and def.passId ~= 0 then
			pcall(function()
				MarketplaceService:PromptGamePassPurchase(player, def.passId)
			end)
		elseif remotes then
			remotes.events.Toast:FireClient(player, "This pass isn't set up yet — soon!", "info")
		end
	end
end

function MonetizationService.init(remoteMap, onDataChanged)
	remotes = remoteMap
	remotes.events.PromptPurchase.OnServerEvent:Connect(onPromptPurchase)

	-- Developer product receipts: grant coins exactly once per PurchaseId.
	MarketplaceService.ProcessReceipt = function(receiptInfo)
		local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
		if not player then
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end
		local data = DataService.get(player)
		if not data then
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end
		if data.grantedReceipts[receiptInfo.PurchaseId] then
			return Enum.ProductPurchaseDecision.PurchaseGranted
		end
		local def = Monetization.findProductByRobloxId(receiptInfo.ProductId)
		if not def then
			-- Unknown product: leave unprocessed so it retries after a fix ships.
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end
		data.grantedReceipts[receiptInfo.PurchaseId] = true
		Economy.addCoins(player, def.coins, def.name)
		DataService.markDirty(player)
		if onDataChanged then onDataChanged(player) end
		return Enum.ProductPurchaseDecision.PurchaseGranted
	end

	-- After a live gamepass purchase, refresh the cache + re-apply benefits.
	MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamePassId, purchased)
		if not purchased then return end
		if passCache[player] then
			for key, def in pairs(Monetization.PassById) do
				if def.passId == gamePassId then
					passCache[player][key] = true
				end
			end
		end
		MonetizationService.applyJoinBenefits(player)
		if onDataChanged then onDataChanged(player) end
	end)

	Players.PlayerRemoving:Connect(function(player)
		passCache[player] = nil
	end)
end

return MonetizationService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0014">
<Properties>
<string name="Name">NPCService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — NPCService
	Blocky townsfolk with names, colors, idle bobbing, gentle wandering, and
	ProximityPrompt dialogue. NPCs are simple anchored models moved by the
	server (cheap, deterministic, no pathfinding needed on flat ground).
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MapData = require(ReplicatedStorage.Shared.MapData)
local BK = require(script.Parent.BuildKit)

local NPCService = {}

local remotes = nil
local npcs = {} -- id -&gt; { model, root, def, homeCF, wanderTarget, dialogueIndex }

local function buildNpcModel(def, parent)
	local m = BK.model("NPC_" .. def.name, parent)
	local skin = Color3.fromRGB(def.skin[1], def.skin[2], def.skin[3])
	local shirt = Color3.fromRGB(def.shirt[1], def.shirt[2], def.shirt[3])
	local pants = Color3.fromRGB(def.pants[1], def.pants[2], def.pants[3])
	-- def.y lets NPCs stand on elevated surfaces (boardwalk/pier decks, floors)
	local baseCF = BK.cfOnGround(def.post[1], def.post[2], 0, def.facing or 0, def.y or 0)

	-- Root (invisible mover everything welds to conceptually; we just CFrame the model)
	local root = BK.part({ Parent = m, Name = "Root", Size = Vector3.new(2, 0.4, 1.4),
		CFrame = baseCF * CFrame.new(0, 0.2, 0), CanCollide = false })
	root.Transparency = 1

	-- Legs, torso, arms, head — friendly proportions
	local function limb(name, size, offset, color)
		return BK.part({ Parent = m, Name = name, Size = size, Color = color,
			Material = Enum.Material.SmoothPlastic, CFrame = baseCF * CFrame.new(offset), CanCollide = (name == "Torso") })
	end
	limb("LegL", Vector3.new(0.9, 2, 0.9), Vector3.new(-0.55, 1, 0), pants)
	limb("LegR", Vector3.new(0.9, 2, 0.9), Vector3.new(0.55, 1, 0), pants)
	limb("Torso", Vector3.new(2.2, 2.4, 1.2), Vector3.new(0, 3.2, 0), shirt)
	limb("ArmL", Vector3.new(0.8, 2.2, 0.8), Vector3.new(-1.55, 3.2, 0), shirt)
	limb("ArmR", Vector3.new(0.8, 2.2, 0.8), Vector3.new(1.55, 3.2, 0), shirt)
	local head = limb("Head", Vector3.new(1.5, 1.5, 1.5), Vector3.new(0, 5.2, 0), skin)

	-- Simple face
	local face = Instance.new("SurfaceGui")
	face.Face = Enum.NormalId.Front
	face.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	face.PixelsPerStud = 40
	face.Parent = head
	local faceLabel = Instance.new("TextLabel")
	faceLabel.Size = UDim2.fromScale(1, 1)
	faceLabel.BackgroundTransparency = 1
	faceLabel.Font = Enum.Font.GothamBold
	faceLabel.TextScaled = true
	faceLabel.Text = "· ·\n‿"
	faceLabel.TextColor3 = Color3.fromRGB(40, 30, 25)
	faceLabel.Parent = face

	BK.billboard(head, def.name, Color3.fromRGB(255, 244, 214), 2.2, 70)

	m.PrimaryPart = root
	return m, root, head
end

local function say(player, def, npc)
	npc.dialogueIndex = (npc.dialogueIndex or 0) + 1
	local line = def.lines[((npc.dialogueIndex - 1) % #def.lines) + 1]
	remotes.events.Toast:FireClient(player, "💬 " .. def.name .. ": " .. line, "npc")
end

function NPCService.init(remoteMap, root)
	remotes = remoteMap
	local folder = BK.model("Townsfolk", root)
	for _, def in ipairs(MapData.NPCs) do
		local model, npcRoot, head = buildNpcModel(def, folder)
		local npc = {
			model = model, root = npcRoot, def = def,
			homeCF = npcRoot.CFrame, dialogueIndex = 0,
			phase = math.random() * math.pi * 2,
		}
		npcs[def.id] = npc
		BK.prompt(head, "Talk", def.name, function(player)
			say(player, def, npc)
		end, 0, 12)
	end

	-- One mover loop for all NPCs: idle bob + slow wander for "wander" kinds.
	task.spawn(function()
		local t = 0
		while true do
			local dt = task.wait(0.1)
			t = t + dt
			for _, npc in pairs(npcs) do
				local def = npc.def
				local target = npc.homeCF
				if def.kind == "wander" then
					if not npc.wanderTarget or (t - (npc.wanderSetAt or 0)) &gt; 6 then
						local r = def.radius or 15
						local a = math.random() * math.pi * 2
						local d = math.random() * r
						npc.wanderTarget = npc.homeCF * CFrame.new(math.cos(a) * d, 0, math.sin(a) * d)
						npc.wanderSetAt = t
					end
					-- ease toward the wander target
					local cur = npc.model.PrimaryPart.CFrame
					local goal = npc.wanderTarget
					local alpha = math.min(1, dt * 0.8)
					local newPos = cur.Position:Lerp(goal.Position, alpha)
					local look = goal.Position - cur.Position
					if look.Magnitude &gt; 0.5 then
						target = CFrame.lookAt(newPos, newPos + Vector3.new(look.X, 0, look.Z))
					else
						target = CFrame.new(newPos) * (cur - cur.Position)
					end
				end
				-- idle bob
				local bob = math.sin(t * 2 + npc.phase) * 0.12
				npc.model:PivotTo(target * CFrame.new(0, bob, 0))
			end
		end
	end)
end

return NPCService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0015">
<Properties>
<string name="Name">PlayerService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — PlayerService
	The join/leave flow and everything per-player that isn't a bigger system's
	job: data load, leaderstats, overhead role titles, emote validation, state
	snapshots to the client, and the welcome toast.
]]

local Players = game:GetService("Players")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local Catalog = require(ReplicatedStorage.Shared.Catalog)
local Monetization = require(ReplicatedStorage.Shared.Monetization)
local DataService = require(script.Parent.DataService)
local Economy = require(script.Parent.Economy)
local MonetizationService = require(script.Parent.MonetizationService)

local PlayerService = {}

local remotes = nil

local function snapshotFor(player)
	local data = DataService.get(player)
	if not data then return nil end
	local fishList = {}
	for fishId, count in pairs(data.fish) do
		fishList[fishId] = count
	end
	return {
		coins = data.coins,
		rodId = data.rodId,
		ownedRods = data.ownedRods,
		ownedEmotes = data.ownedEmotes,
		fish = fishList,
		totalCatches = data.totalCatches,
		cottagePaint = data.cottagePaint,
		roleTitleIndex = data.roleTitleIndex,
		passes = {
			vip = MonetizationService.ownsPass(player, "vip"),
			angler = MonetizationService.ownsPass(player, "angler"),
			deluxe_home = MonetizationService.ownsPass(player, "deluxe_home"),
			emotes = MonetizationService.ownsPass(player, "emotes"),
		},
	}
end

function PlayerService.pushSnapshot(player)
	local snap = snapshotFor(player)
	if snap then
		remotes.events.DataSync:FireClient(player, snap)
	end
end

local function applyTitle(player)
	local data = DataService.get(player)
	if not data then return end
	local char = player.Character
	local head = char and char:FindFirstChild("Head")
	if not head then return end
	local old = head:FindFirstChild("RoleTitle")
	if old then old:Destroy() end
	local isVip = MonetizationService.ownsPass(player, "vip")
	local title = Config.RoleTitles[data.roleTitleIndex] or Config.RoleTitles[1]
	local bb = Instance.new("BillboardGui")
	bb.Name = "RoleTitle"
	bb.Size = UDim2.fromOffset(200, 28)
	bb.StudsOffset = Vector3.new(0, 2.4, 0)
	bb.AlwaysOnTop = false
	bb.MaxDistance = 60
	bb.Parent = head
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.Text = (isVip and "⭐ " or "") .. title
	label.TextColor3 = isVip and Color3.fromRGB(255, 215, 90) or Color3.fromRGB(235, 240, 245)
	label.TextStrokeTransparency = 0.4
	label.TextScaled = true
	label.Parent = bb
end

local function onSetRoleTitle(player, index)
	if type(index) ~= "number" then return end
	index = math.floor(index)
	if index &lt; 1 or index &gt; #Config.RoleTitles then return end
	local data = DataService.get(player)
	if not data then return end
	data.roleTitleIndex = index
	DataService.markDirty(player)
	applyTitle(player)
	PlayerService.pushSnapshot(player)
end

local function onPlayEmote(player, emoteId)
	if type(emoteId) ~= "string" then return end
	local def = Catalog.EmoteById[emoteId]
	local animId = nil
	if def then
		if def.free then
			animId = def.animId
		else
			local data = DataService.get(player)
			if data and data.ownedEmotes[emoteId] then
				animId = def.animId
			end
		end
	else
		-- pass-exclusive emotes live in the Monetization module
		for _, e in ipairs(Monetization.PassEmotes) do
			if e.id == emoteId then
				local data = DataService.get(player)
				if data and data.ownedEmotes[emoteId] then
					animId = e.animId
				end
			end
		end
	end
	if animId then
		remotes.events.EmoteApproved:FireClient(player, emoteId, animId)
	else
		remotes.events.Toast:FireClient(player, "You haven't unlocked that emote.", "warn")
	end
end

local function onPlayerAdded(player)
	local data = DataService.load(player)
	Economy.setupLeaderstats(player)
	MonetizationService.applyJoinBenefits(player)

	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		applyTitle(player)
	end)
	if player.Character then
		applyTitle(player)
	end

	-- Push the loaded state now that it exists — the client's one-shot
	-- GetInitialState can race a slow DataStore load and get nil.
	PlayerService.pushSnapshot(player)

	task.delay(2, function()
		if not player.Parent then return end
		if data.firstJoin then
			remotes.events.Toast:FireClient(player,
				"🌊 Welcome to Lanternside Bay! Grab a job at the notice board, cast a line off the pier, and claim yourself a cottage.", "info")
		else
			remotes.events.Toast:FireClient(player, "🌊 Welcome back to the bay.", "info")
		end
	end)
end

function PlayerService.init(remoteMap)
	remotes = remoteMap
	remotes.events.SetRoleTitle.OnServerEvent:Connect(onSetRoleTitle)
	remotes.events.PlayEmote.OnServerEvent:Connect(onPlayEmote)
	remotes.functions.GetInitialState.OnServerInvoke = function(player)
		return snapshotFor(player)
	end
	Players.PlayerAdded:Connect(onPlayerAdded)
	-- Players who joined before this connected (fast joins in Studio)
	for _, player in ipairs(Players:GetPlayers()) do
		task.spawn(onPlayerAdded, player)
	end
	Players.PlayerRemoving:Connect(function(player)
		DataService.release(player)
	end)
end

return PlayerService
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0016">
<Properties>
<string name="Name">Remotes</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Remotes
	Creates every RemoteEvent/RemoteFunction under ReplicatedStorage.Remotes.
	One place to see the entire client&lt;-&gt;server surface area.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Remotes = {}

local EVENTS = {
	-- server -&gt; client
	"Toast",            -- (text, kind) little HUD notifications
	"DataSync",         -- (dataSnapshot) full player-state push for UI
	"FishingState",     -- (state, payload) casting/bite/caught updates
	"JobState",         -- (state, payload) current task updates
	"TimeOfDay",        -- (hour) broadcast a few times a minute for clock UI
	"EmoteApproved",    -- (emoteId, animId) server OK'd; client plays it
	"OpenUI",           -- (panelName) world prompts opening client panels
	-- client -&gt; server
	"BuyItem",          -- (itemId) coin purchases
	"SellFish",         -- () sell all carried fish at the market
	"CastLine",         -- (spotIndex)
	"ReelIn",           -- ()
	"TakeJob",          -- (jobId or nil to quit)
	"JobAction",        -- (actionId) brew/knead/bake/collect/deliver etc.
	"ClaimCottage",     -- (cottageId or nil to unclaim)
	"PaintCottage",     -- (paletteId)
	"ToggleLock",       -- ()
	"SetRoleTitle",     -- (index into Config.RoleTitles)
	"PlayEmote",        -- (emoteId) validation; anim plays client-side
	"EquipRod",         -- (rodId)
	"PromptPurchase",   -- (kind, id) kind = "product"|"pass"
}

local FUNCTIONS = {
	"GetInitialState", -- () -&gt; full snapshot (map ids, catalog ownership, etc.)
}

function Remotes.init()
	local folder = Instance.new("Folder")
	folder.Name = "Remotes"
	folder.Parent = ReplicatedStorage
	local map = { events = {}, functions = {} }
	for _, name in ipairs(EVENTS) do
		local ev = Instance.new("RemoteEvent")
		ev.Name = name
		ev.Parent = folder
		map.events[name] = ev
	end
	for _, name in ipairs(FUNCTIONS) do
		local fn = Instance.new("RemoteFunction")
		fn.Name = name
		fn.Parent = folder
		map.functions[name] = fn
	end
	return map
end

return Remotes
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0017">
<Properties>
<string name="Name">ShopService</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — ShopService
	Coin purchases (rods, treats, emotes), rod equipping, and the little
	hand-held treat props. Everything validated against the catalog and the
	player's server-side balance.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Catalog = require(ReplicatedStorage.Shared.Catalog)
local DataService = require(script.Parent.DataService)
local Economy = require(script.Parent.Economy)
local BK = require(script.Parent.BuildKit)

local ShopService = {}

local remotes = nil
local pushSnapshot = nil

local TREAT_COLORS = {
	icecream = Color3.fromRGB(240, 225, 235),
	cocoa = Color3.fromRGB(120, 80, 60),
	pretzel = Color3.fromRGB(190, 140, 80),
}

local function giveTreatProp(player, itemId)
	local char = player.Character
	if not char then return end
	local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
	if not hand then return end
	local old = char:FindFirstChild("TreatProp")
	if old then old:Destroy() end
	local prop = Instance.new("Part")
	prop.Name = "TreatProp"
	prop.Size = Vector3.new(0.7, 1.4, 0.7)
	prop.Color = TREAT_COLORS[itemId] or Color3.fromRGB(240, 240, 240)
	prop.Material = Enum.Material.SmoothPlastic
	prop.CanCollide = false
	prop.Massless = true
	prop.CFrame = hand.CFrame * CFrame.new(0, -1, 0)
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = hand
	weld.Part1 = prop
	weld.Parent = prop
	prop.Parent = char
	task.delay(90, function()
		if prop.Parent then prop:Destroy() end
	end)
end

local function onBuyItem(player, itemId)
	if type(itemId) ~= "string" then return end
	local item = Catalog.ShopById[itemId]
	if not item then return end
	local data = DataService.get(player)
	if not data then return end

	if item.kind == "rod" then
		if data.ownedRods[itemId] then
			remotes.events.Toast:FireClient(player, "You already own that rod.", "info")
			return
		end
		if not Economy.spendCoins(player, item.price) then
			remotes.events.Toast:FireClient(player, "Not enough coins!", "warn")
			return
		end
		data.ownedRods[itemId] = true
		data.rodId = itemId
		DataService.markDirty(player)
		remotes.events.Toast:FireClient(player, "🎣 " .. item.name .. " bought and equipped!", "coins")
	elseif item.kind == "emote" then
		if data.ownedEmotes[itemId] then
			remotes.events.Toast:FireClient(player, "You already know that emote.", "info")
			return
		end
		if not Economy.spendCoins(player, item.price) then
			remotes.events.Toast:FireClient(player, "Not enough coins!", "warn")
			return
		end
		data.ownedEmotes[itemId] = true
		DataService.markDirty(player)
		remotes.events.Toast:FireClient(player, "🕺 " .. item.name .. " learned!", "coins")
	elseif item.kind == "treat" then
		if not Economy.spendCoins(player, item.price) then
			remotes.events.Toast:FireClient(player, "Not enough coins!", "warn")
			return
		end
		giveTreatProp(player, itemId)
		remotes.events.Toast:FireClient(player, item.name .. " — enjoy!", "coins")
	end
	if pushSnapshot then pushSnapshot(player) end
end

local function onEquipRod(player, rodId)
	if type(rodId) ~= "string" then return end
	local data = DataService.get(player)
	if not data then return end
	if not data.ownedRods[rodId] then
		remotes.events.Toast:FireClient(player, "You don't own that rod yet.", "warn")
		return
	end
	data.rodId = rodId
	DataService.markDirty(player)
	local rodName = rodId == "moonlit" and "Moonlit Rod" or (Catalog.RodById[rodId] and Catalog.RodById[rodId].name or rodId)
	remotes.events.Toast:FireClient(player, "🎣 Equipped the " .. rodName .. ".", "info")
	if pushSnapshot then pushSnapshot(player) end
end

function ShopService.init(remoteMap, anchors, snapshotPusher)
	remotes = remoteMap
	pushSnapshot = snapshotPusher
	remotes.events.BuyItem.OnServerEvent:Connect(onBuyItem)
	remotes.events.EquipRod.OnServerEvent:Connect(onEquipRod)

	-- World prompts: store counter opens the shop, Scoops sells ice cream directly.
	if anchors then
		BK.prompt(anchors.shops.store.counter, "Browse the shop", "Lanternside General", function(player)
			remotes.events.OpenUI:FireClient(player, "shop")
		end, 0, 12)
		BK.prompt(anchors.waterfront.scoopsCounter, "Buy Sea-Salt Swirl (10c)", "Scoops", function(player)
			onBuyItem(player, "icecream")
		end, 0.3, 10)
	end
end

return ShopService
</ProtectedString>
</Properties>

</Item>
</Item>
</Item>
<Item class="StarterPlayer" referent="RBX0034">
<Properties>
<string name="Name">StarterPlayer</string>
</Properties>
<Item class="StarterPlayerScripts" referent="RBX0033">
<Properties>
<string name="Name">StarterPlayerScripts</string>
</Properties>
<Item class="LocalScript" referent="RBX0023">
<Properties>
<string name="Name">ClientMain</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — client bootstrap
	Builds the HUD + panels, keeps a local state snapshot in sync with the
	server, plays approved emotes, and relays world-prompt UI opens.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Wait for the server to publish its remotes
local remotesFolder = ReplicatedStorage:WaitForChild("Remotes", 30)
if not remotesFolder then
	warn("[Lanternside] Remotes never appeared; is the server script running?")
	return
end

local remotes = { events = {}, functions = {} }
for _, child in ipairs(remotesFolder:GetChildren()) do
	if child:IsA("RemoteEvent") then
		remotes.events[child.Name] = child
	elseif child:IsA("RemoteFunction") then
		remotes.functions[child.Name] = child
	end
end

local HUD = require(script.HUD)
local Panels = require(script.Panels)
local FishingClient = require(script.FishingClient)

-- Local state snapshot ------------------------------------------------------
local state = {
	coins = 0, rodId = "driftwood", ownedRods = { driftwood = true },
	ownedEmotes = {}, fish = {}, totalCatches = 0,
	cottagePaint = "seafoam", roleTitleIndex = 1, passes = {},
}

local function applySnapshot(snap)
	if type(snap) ~= "table" then return end
	for k, v in pairs(snap) do
		state[k] = v
	end
	HUD.setCoins(state.coins)
	Panels.refreshOpen()
end

-- UI ------------------------------------------------------------------------
local gui = HUD.build(playerGui, function(buttonName)
	Panels.toggle(buttonName)
end)
Panels.build(gui, remotes, function()
	return state
end)
FishingClient.build(gui, remotes)

-- Server events ---------------------------------------------------------------
remotes.events.Toast.OnClientEvent:Connect(function(text, kind)
	HUD.toast(text, kind)
end)

remotes.events.DataSync.OnClientEvent:Connect(applySnapshot)

remotes.events.TimeOfDay.OnClientEvent:Connect(function(hour)
	HUD.setClock(hour)
end)

remotes.events.JobState.OnClientEvent:Connect(function(kind, payload)
	if kind == "task" then
		Panels.setCurrentJob(payload.jobId)
		HUD.setTracker("💼 " .. (payload.targetName or ""))
	else
		Panels.setCurrentJob(nil)
		HUD.setTracker(nil)
	end
end)

remotes.events.OpenUI.OnClientEvent:Connect(function(panelName)
	Panels.open(panelName)
end)

-- Emotes: server approves, we animate our own character (replicates to all).
local currentTrack = nil
remotes.events.EmoteApproved.OnClientEvent:Connect(function(emoteId, animId)
	local char = player.Character
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end
	if currentTrack then
		currentTrack:Stop(0.15)
		currentTrack = nil
	end
	local anim = Instance.new("Animation")
	anim.AnimationId = animId
	local ok, track = pcall(function()
		return animator:LoadAnimation(anim)
	end)
	if ok and track then
		track.Priority = Enum.AnimationPriority.Action
		track:Play(0.15)
		currentTrack = track
		task.delay(6, function()
			if currentTrack == track then
				track:Stop(0.3)
				currentTrack = nil
			end
		end)
	end
end)

-- Initial state fetch ------------------------------------------------------------
task.spawn(function()
	local ok, snap = pcall(function()
		return remotes.functions.GetInitialState:InvokeServer()
	end)
	if ok then
		applySnapshot(snap)
	end
end)

print("[Lanternside] Client ready.")
</ProtectedString>
</Properties>
<Item class="ModuleScript" referent="RBX0019">
<Properties>
<string name="Name">FishingClient</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — FishingClient
	Renders the fishing loop: waiting state, the big REEL button on a bite
	(tap-friendly), Space as a keyboard shortcut, and the catch celebration.
]]

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Catalog = require(ReplicatedStorage.Shared.Catalog)
local UIKit = require(script.Parent.UIKit)

local FishingClient = {}

local remotes = nil
local statusFrame = nil
local statusLabel = nil
local reelButton = nil
local state = "idle" -- idle | waiting | bite

local function setStatus(text, visible)
	statusLabel.Text = text or ""
	statusFrame.Visible = visible and text ~= nil
end

local function onFishingState(kind, payload)
	if kind == "cast" then
		state = "waiting"
		reelButton.Visible = false
		setStatus("🎣 Line's in the water...", true)
	elseif kind == "bite" then
		state = "bite"
		setStatus(nil, false)
		reelButton.Visible = true
		reelButton.Size = UDim2.fromOffset(200, 64)
		TweenService:Create(reelButton, TweenInfo.new(0.12, Enum.EasingStyle.Back), {
			Size = UDim2.fromOffset(230, 74),
		}):Play()
	elseif kind == "escaped" then
		state = "idle"
		reelButton.Visible = false
		setStatus("💨 It got away...", true)
		task.delay(1.6, function()
			if state == "idle" then setStatus(nil, false) end
		end)
	elseif kind == "reeled_early" then
		state = "idle"
		reelButton.Visible = false
		setStatus("Nothing on the line yet.", true)
		task.delay(1.4, function()
			if state == "idle" then setStatus(nil, false) end
		end)
	elseif kind == "caught" then
		state = "idle"
		reelButton.Visible = false
		local rarity = payload.rarity or "common"
		local color = Catalog.RarityColors[rarity] or Color3.fromRGB(255, 255, 255)
		local stars = { common = "", uncommon = "★", rare = "★★", epic = "★★★" }
		setStatus(("🐟 %s %s  (worth %dc)"):format(payload.name or "A fish", stars[rarity] or "", payload.value or 0), true)
		statusFrame.BackgroundColor3 = color
		task.delay(2.2, function()
			statusFrame.BackgroundColor3 = UIKit.Colors.Night
			if state == "idle" then setStatus(nil, false) end
		end)
	end
end

local function reel()
	if state == "bite" or state == "waiting" then
		remotes.events.ReelIn:FireServer()
	end
end

function FishingClient.build(gui, remoteMap)
	remotes = remoteMap

	statusFrame = UIKit.frame({
		Name = "FishingStatus", Parent = gui, Visible = false,
		Size = UDim2.fromOffset(320, 44), Position = UDim2.new(0.5, 0, 1, -130),
		AnchorPoint = Vector2.new(0.5, 1), Color = UIKit.Colors.Night,
		Transparency = 0.1, CornerRadius = 12,
	})
	statusLabel = UIKit.label({
		Parent = statusFrame, Text = "", TextColor = Color3.fromRGB(240, 244, 250),
		Size = UDim2.new(1, -20, 1, 0), Position = UDim2.fromOffset(10, 0),
		XAlign = Enum.TextXAlignment.Center, Font = Enum.Font.GothamBold, TextSize = 16,
	})

	reelButton = UIKit.button({
		Name = "ReelButton", Parent = gui, Text = "❗ REEL IN ❗",
		Size = UDim2.fromOffset(200, 64), Position = UDim2.new(0.5, 0, 1, -140),
		AnchorPoint = Vector2.new(0.5, 1), Color = UIKit.Colors.Danger,
		TextSize = 24, CornerRadius = 16,
		OnClick = reel,
	})
	reelButton.Visible = false
	UIKit.stroke(reelButton, Color3.fromRGB(255, 255, 255), 2, 0.4)

	remotes.events.FishingState.OnClientEvent:Connect(onFishingState)

	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.Space and state == "bite" then
			reel()
		end
	end)
end

return FishingClient
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0020">
<Properties>
<string name="Name">HUD</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — HUD (client)
	Top bar (coins / clock / title), bottom menu buttons, toast stack, and the
	job objective tracker. Panels themselves live in Panels.lua.
]]

local TweenService = game:GetService("TweenService")

local UIKit = require(script.Parent.UIKit)

local HUD = {}

local gui = nil
local coinsLabel = nil
local clockLabel = nil
local trackerFrame = nil
local trackerLabel = nil
local toastHolder = nil
local buttonsByName = {}

function HUD.build(playerGui, onMenuButton)
	gui = Instance.new("ScreenGui")
	gui.Name = "LanternsideHUD"
	gui.ResetOnSpawn = false
	gui.IgnoreGuiInset = false
	-- Script-created ScreenGuis default to legacy Global z-sorting, which
	-- draws low-ZIndex children UNDER their high-ZIndex ancestors (the empty
	-- shop bug). Sibling is the modern behavior all our layering assumes.
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = playerGui

	-- Top bar --------------------------------------------------------------
	local top = UIKit.frame({
		Name = "TopBar", Parent = gui,
		Size = UDim2.fromOffset(320, 44), Position = UDim2.new(0.5, 0, 0, 8),
		AnchorPoint = Vector2.new(0.5, 0), Transparency = 0.08, CornerRadius = 12,
	})
	UIKit.stroke(top, Color3.fromRGB(215, 205, 188), 1.5)
	coinsLabel = UIKit.label({
		Parent = top, Text = "🪙 0", Font = Enum.Font.GothamBold,
		Size = UDim2.new(0.45, 0, 1, 0), Position = UDim2.fromOffset(14, 0), TextSize = 18,
	})
	clockLabel = UIKit.label({
		Parent = top, Text = "☀️ 9:00", Font = Enum.Font.GothamBold,
		Size = UDim2.new(0.5, -14, 1, 0), Position = UDim2.new(0.5, 0, 0, 0),
		XAlign = Enum.TextXAlignment.Right, TextSize = 18, TextColor = UIKit.Colors.InkSoft,
	})

	-- Job tracker ----------------------------------------------------------
	trackerFrame = UIKit.frame({
		Name = "JobTracker", Parent = gui, Visible = false,
		Size = UDim2.fromOffset(340, 54), Position = UDim2.new(0.5, 0, 0, 58),
		AnchorPoint = Vector2.new(0.5, 0), Transparency = 0.12, CornerRadius = 10,
		Color = UIKit.Colors.Night,
	})
	trackerLabel = UIKit.label({
		Parent = trackerFrame, Text = "", TextColor = Color3.fromRGB(240, 244, 250),
		Size = UDim2.new(1, -20, 1, 0), Position = UDim2.fromOffset(10, 0),
		TextSize = 15, Font = Enum.Font.GothamMedium, XAlign = Enum.TextXAlignment.Center,
	})

	-- Bottom menu buttons -----------------------------------------------------
	local bottom = UIKit.frame({
		Name = "Menu", Parent = gui, Transparency = 1, Corner = false,
		Size = UDim2.fromOffset(420, 56), Position = UDim2.new(0.5, 0, 1, -12),
		AnchorPoint = Vector2.new(0.5, 1),
	})
	local layout = UIKit.list(bottom, 10, Enum.FillDirection.Horizontal)
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	local defs = {
		{ name = "shop", text = "🛍️ Shop" },
		{ name = "jobs", text = "💼 Jobs" },
		{ name = "style", text = "🕺 Style" },
		{ name = "house", text = "🏠 House" },
		{ name = "help", text = "❓" },
	}
	for i, def in ipairs(defs) do
		local b = UIKit.button({
			Parent = bottom, Text = def.text, TextSize = 16,
			Size = def.name == "help" and UDim2.fromOffset(48, 46) or UDim2.fromOffset(88, 46),
			Color = UIKit.Colors.Teal, CornerRadius = 12,
			OnClick = function()
				onMenuButton(def.name)
			end,
		})
		b.LayoutOrder = i
		buttonsByName[def.name] = b
	end

	-- Toast stack -------------------------------------------------------------
	toastHolder = UIKit.frame({
		Name = "Toasts", Parent = gui, Transparency = 1, Corner = false,
		Size = UDim2.fromOffset(380, 300), Position = UDim2.new(0.5, 0, 0, 120),
		AnchorPoint = Vector2.new(0.5, 0),
	})
	local tl = UIKit.list(toastHolder, 6)
	tl.HorizontalAlignment = Enum.HorizontalAlignment.Center

	return gui
end

local TOAST_COLORS = {
	coins = UIKit.Colors.Gold,
	warn = UIKit.Colors.Danger,
	info = UIKit.Colors.Teal,
	npc = UIKit.Colors.Night,
}

function HUD.toast(text, kind)
	if not toastHolder then return end
	local color = TOAST_COLORS[kind or "info"] or UIKit.Colors.Teal
	local t = UIKit.frame({
		Parent = toastHolder, Transparency = 0.06, CornerRadius = 10,
		Size = UDim2.new(1, -20, 0, 40), Color = UIKit.Colors.Cream,
	})
	t.AutomaticSize = Enum.AutomaticSize.Y
	UIKit.stroke(t, color, 2)
	local lbl = UIKit.label({
		Parent = t, Text = text, TextSize = 15, Font = Enum.Font.GothamMedium,
		Size = UDim2.new(1, -20, 0, 0), Position = UDim2.fromOffset(10, 0),
		XAlign = Enum.TextXAlignment.Center,
	})
	lbl.AutomaticSize = Enum.AutomaticSize.Y
	UIKit.padding(lbl, 10)
	task.delay(3.5, function()
		local fade = TweenService:Create(t, TweenInfo.new(0.5), { BackgroundTransparency = 1 })
		fade:Play()
		TweenService:Create(lbl, TweenInfo.new(0.5), { TextTransparency = 1 }):Play()
		fade.Completed:Wait()
		t:Destroy()
	end)
end

function HUD.setCoins(amount)
	if coinsLabel then
		coinsLabel.Text = "🪙 " .. tostring(amount)
	end
end

function HUD.setClock(hour)
	if not clockLabel then return end
	local h = math.floor(hour)
	local m = math.floor((hour - h) * 60)
	local isNight = hour &gt;= 18.5 or hour &lt; 6
	local suffix = h &gt;= 12 and "PM" or "AM"
	local displayH = h % 12
	if displayH == 0 then displayH = 12 end
	clockLabel.Text = string.format("%s %d:%02d %s", isNight and "🌙" or "☀️", displayH, m, suffix)
end

function HUD.setTracker(text)
	if not trackerFrame then return end
	if text and text ~= "" then
		trackerFrame.Visible = true
		trackerLabel.Text = text
	else
		trackerFrame.Visible = false
	end
end

return HUD
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0021">
<Properties>
<string name="Name">Panels</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — Panels (client)
	The window UIs: Shop (coins + Robux tabs), Jobs board, Style (emotes &amp;
	titles), House, and Help. Each rebuilds its rows from the latest state
	snapshot every time it's shown, so nothing ever goes stale.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage.Shared.Config)
local Catalog = require(ReplicatedStorage.Shared.Catalog)
local Monetization = require(ReplicatedStorage.Shared.Monetization)
local UIKit = require(script.Parent.UIKit)

local Panels = {}

local remotes = nil
local getState = nil
local panels = {}

-- Generic list row: icon+name+desc on the left, action button on the right.
local function row(parent, order, icon, name, desc, buttonText, buttonColor, onClick, buttonDisabled)
	local r = UIKit.frame({
		Parent = parent, Color = UIKit.Colors.CreamDark, CornerRadius = 10,
		Size = UDim2.new(1, -8, 0, 64),
	})
	r.LayoutOrder = order
	UIKit.label({
		Parent = r, Text = icon, TextSize = 26, Font = Enum.Font.GothamBold,
		Size = UDim2.fromOffset(44, 64), Position = UDim2.fromOffset(8, 0),
		XAlign = Enum.TextXAlignment.Center,
	})
	UIKit.label({
		Parent = r, Text = name, Font = Enum.Font.GothamBold, TextSize = 16,
		Size = UDim2.new(1, -190, 0, 26), Position = UDim2.fromOffset(56, 6),
	})
	UIKit.label({
		Parent = r, Text = desc, TextSize = 13, TextColor = UIKit.Colors.InkSoft,
		Size = UDim2.new(1, -190, 0, 28), Position = UDim2.fromOffset(56, 30),
		YAlign = Enum.TextYAlignment.Top,
	})
	if buttonText then
		local b = UIKit.button({
			Parent = r, Text = buttonText, TextSize = 14,
			Size = UDim2.fromOffset(112, 40), Position = UDim2.new(1, -122, 0.5, 0),
			AnchorPoint = Vector2.new(0, 0.5),
			Color = buttonColor or UIKit.Colors.Teal,
			OnClick = onClick,
		})
		if buttonDisabled then
			b.BackgroundColor3 = Color3.fromRGB(180, 180, 175)
			b.AutoButtonColor = false
		end
		return r, b
	end
	return r
end

-- SHOP ---------------------------------------------------------------------------

local function rebuildShop(content)
	for _, child in ipairs(content:GetChildren()) do
		if child.Name == "Rows" then child:Destroy() end
	end
	local state = getState()
	local holder = UIKit.scroll({ Parent = content, Name = "Rows", Size = UDim2.new(1, 0, 1, -46), Position = UDim2.fromOffset(0, 46) })
	UIKit.list(holder, 8)
	local mode = content:GetAttribute("Tab") or "coins"
	local order = 0

	if mode == "coins" then
		for _, item in ipairs(Catalog.ShopItems) do
			order = order + 1
			local owned = false
			local buttonText = item.price .. "c"
			if item.kind == "rod" then
				owned = state.ownedRods and state.ownedRods[item.id]
				if owned then
					local equipped = state.rodId == item.id
					row(holder, order, "🎣", item.name, item.desc,
						equipped and "Equipped" or "Equip",
						equipped and UIKit.Colors.Gold or UIKit.Colors.Night,
						function()
							remotes.events.EquipRod:FireServer(item.id)
						end, equipped)
				else
					row(holder, order, "🎣", item.name, item.desc, buttonText, UIKit.Colors.Teal, function()
						remotes.events.BuyItem:FireServer(item.id)
					end)
				end
			elseif item.kind == "emote" then
				owned = state.ownedEmotes and state.ownedEmotes[item.id]
				row(holder, order, "🕺", item.name, item.desc,
					owned and "Owned" or buttonText,
					owned and UIKit.Colors.Gold or UIKit.Colors.Teal,
					owned and nil or function()
						remotes.events.BuyItem:FireServer(item.id)
					end, owned)
			else
				row(holder, order, "🍦", item.name, item.desc, buttonText, UIKit.Colors.Teal, function()
					remotes.events.BuyItem:FireServer(item.id)
				end)
			end
		end
		-- Master Angler rod teaser (owned via pass)
		if state.passes and state.passes.angler then
			order = order + 1
			local equipped = state.rodId == "moonlit"
			row(holder, order, "🌙", "Moonlit Rod", "Master Angler exclusive — best luck in the bay.",
				equipped and "Equipped" or "Equip",
				equipped and UIKit.Colors.Gold or UIKit.Colors.Night,
				function()
					remotes.events.EquipRod:FireServer("moonlit")
				end, equipped)
		end
	else
		-- Robux tab: coin packs (developer products), then passes
		order = order + 1
		local head1 = UIKit.label({
			Parent = holder, Text = "COIN PACKS", Font = Enum.Font.GothamBold,
			TextSize = 13, TextColor = UIKit.Colors.InkSoft, Size = UDim2.new(1, 0, 0, 22),
		})
		head1.LayoutOrder = order
		for _, p in ipairs(Monetization.Products) do
			order = order + 1
			local ready = p.productId ~= 0
			row(holder, order, p.icon, p.name, p.desc,
				ready and "Buy  " or "Soon", ready and UIKit.Colors.Gold or nil,
				function()
					remotes.events.PromptPurchase:FireServer("product", p.id)
				end, not ready)
		end
		order = order + 1
		local head2 = UIKit.label({
			Parent = holder, Text = "GAME PASSES", Font = Enum.Font.GothamBold,
			TextSize = 13, TextColor = UIKit.Colors.InkSoft, Size = UDim2.new(1, 0, 0, 22),
		})
		head2.LayoutOrder = order
		for _, p in ipairs(Monetization.Passes) do
			order = order + 1
			local owned = state.passes and state.passes[p.id]
			local ready = p.passId ~= 0
			row(holder, order, p.icon, p.name, p.desc,
				owned and "Owned" or (ready and "Buy  " or "Soon"),
				owned and UIKit.Colors.Gold or (ready and UIKit.Colors.Gold or nil),
				owned and nil or function()
					remotes.events.PromptPurchase:FireServer("pass", p.id)
				end, owned or not ready)
		end
	end
end

local function buildShop(gui)
	local overlay, content = UIKit.panel(gui, "ShopPanel", "🛍️ Lanternside General", UDim2.fromOffset(480, 460))
	content:SetAttribute("Tab", "coins")
	local tabs = UIKit.frame({ Parent = content, Transparency = 1, Corner = false, Size = UDim2.new(1, 0, 0, 38) })
	UIKit.list(tabs, 8, Enum.FillDirection.Horizontal)
	local coinTab, robuxTab
	coinTab = UIKit.button({
		Parent = tabs, Text = "🪙 Coins Shop", Size = UDim2.fromOffset(140, 34),
		Color = UIKit.Colors.Teal,
		OnClick = function()
			content:SetAttribute("Tab", "coins")
			coinTab.BackgroundColor3 = UIKit.Colors.Teal
			robuxTab.BackgroundColor3 = UIKit.Colors.InkSoft
			rebuildShop(content)
		end,
	})
	robuxTab = UIKit.button({
		Parent = tabs, Text = "💎 Robux", Size = UDim2.fromOffset(120, 34),
		Color = UIKit.Colors.InkSoft,
		OnClick = function()
			content:SetAttribute("Tab", "robux")
			coinTab.BackgroundColor3 = UIKit.Colors.InkSoft
			robuxTab.BackgroundColor3 = UIKit.Colors.Gold
			rebuildShop(content)
		end,
	})
	panels.shop = { overlay = overlay, rebuild = function() rebuildShop(content) end }
end

-- JOBS ----------------------------------------------------------------------------

local currentJobId = nil -- mirrored from JobState events

local function rebuildJobs(content)
	for _, child in ipairs(content:GetChildren()) do
		if child.Name == "Rows" then child:Destroy() end
	end
	local holder = UIKit.scroll({ Parent = content, Name = "Rows" })
	UIKit.list(holder, 8)
	for i, job in ipairs(Catalog.JobList) do
		local mine = currentJobId == job.id
		row(holder, i, job.icon, job.name .. "  ·  " .. job.place, job.desc,
			mine and "Quit" or "Take job",
			mine and UIKit.Colors.Danger or UIKit.Colors.Teal,
			function()
				if mine then
					remotes.events.TakeJob:FireServer(nil)
				else
					remotes.events.TakeJob:FireServer(job.id)
				end
				panels.jobs.overlay.Visible = false
			end)
	end
	UIKit.label({
		Parent = holder, TextSize = 13, TextColor = UIKit.Colors.InkSoft,
		Text = "Walk to your workplace and follow the glowing props. Every "
			.. Config.Jobs.StreakBonusEvery .. " tasks pays a +" .. Config.Jobs.StreakBonusCoins .. " streak bonus. ⭐ VIP pays double.",
		Size = UDim2.new(1, -8, 0, 40),
	}).LayoutOrder = 99
end

local function buildJobs(gui)
	local overlay, content = UIKit.panel(gui, "JobsPanel", "💼 Notice Board", UDim2.fromOffset(470, 380))
	panels.jobs = { overlay = overlay, rebuild = function() rebuildJobs(content) end }
end

function Panels.setCurrentJob(jobId)
	currentJobId = jobId
end

-- STYLE (emotes + titles) ------------------------------------------------------------

local function rebuildStyle(content)
	for _, child in ipairs(content:GetChildren()) do
		if child.Name == "Rows" then child:Destroy() end
	end
	local state = getState()
	local holder = UIKit.scroll({ Parent = content, Name = "Rows" })
	UIKit.list(holder, 8)
	local order = 0

	order = order + 1
	local h1 = UIKit.label({
		Parent = holder, Text = "EMOTES", Font = Enum.Font.GothamBold,
		TextSize = 13, TextColor = UIKit.Colors.InkSoft, Size = UDim2.new(1, 0, 0, 22),
	})
	h1.LayoutOrder = order

	local allEmotes = {}
	for _, e in ipairs(Catalog.Emotes) do allEmotes[#allEmotes + 1] = e end
	for _, e in ipairs(Monetization.PassEmotes) do
		allEmotes[#allEmotes + 1] = { id = e.id, name = e.name, free = false, passOnly = e.pass }
	end
	for _, e in ipairs(allEmotes) do
		local owned = e.free or (state.ownedEmotes and state.ownedEmotes[e.id])
		order = order + 1
		local hint
		if owned then
			hint = "Tap to perform."
		elseif e.passOnly then
			hint = "Unlocks with the " .. (Monetization.PassById[e.passOnly] and Monetization.PassById[e.passOnly].name or "pass") .. "."
		else
			hint = "Available in the shop."
		end
		row(holder, order, owned and "🕺" or "🔒", e.name, hint,
			owned and "Play" or "Locked",
			owned and UIKit.Colors.Teal or nil,
			owned and function()
				remotes.events.PlayEmote:FireServer(e.id)
			end or nil, not owned)
	end

	order = order + 1
	local h2 = UIKit.label({
		Parent = holder, Text = "OVERHEAD TITLE", Font = Enum.Font.GothamBold,
		TextSize = 13, TextColor = UIKit.Colors.InkSoft, Size = UDim2.new(1, 0, 0, 22),
	})
	h2.LayoutOrder = order
	for i, title in ipairs(Config.RoleTitles) do
		order = order + 1
		local active = state.roleTitleIndex == i
		row(holder, order, "🏷️", title, active and "Currently shown over your head." or "",
			active and "Worn" or "Wear",
			active and UIKit.Colors.Gold or UIKit.Colors.Night,
			active and nil or function()
				remotes.events.SetRoleTitle:FireServer(i)
			end, active)
	end
end

local function buildStyle(gui)
	local overlay, content = UIKit.panel(gui, "StylePanel", "🕺 Style", UDim2.fromOffset(470, 460))
	panels.style = { overlay = overlay, rebuild = function() rebuildStyle(content) end }
end

-- HOUSE --------------------------------------------------------------------------------

local function rebuildHouse(content)
	for _, child in ipairs(content:GetChildren()) do
		if child.Name == "Rows" then child:Destroy() end
	end
	local state = getState()
	local holder = UIKit.scroll({ Parent = content, Name = "Rows" })
	UIKit.list(holder, 8)

	local intro = UIKit.label({
		Parent = holder, TextSize = 14, TextColor = UIKit.Colors.InkSoft,
		Text = "Claim any cottage by holding its porch sign. Your paint color is saved forever; the cottage itself frees up when you leave town.",
		Size = UDim2.new(1, -8, 0, 44),
	})
	intro.LayoutOrder = 1

	row(holder, 2, "🔒", "Door lock", "Toggle a gentle door ward. You always pass through your own.",
		"Toggle", UIKit.Colors.Night, function()
			remotes.events.ToggleLock:FireServer()
		end)
	row(holder, 3, "📦", "Move out", "Unclaim your cottage for someone else.",
		"Unclaim", UIKit.Colors.Danger, function()
			remotes.events.ClaimCottage:FireServer(nil)
		end)

	local h = UIKit.label({
		Parent = holder, Text = "PAINT", Font = Enum.Font.GothamBold,
		TextSize = 13, TextColor = UIKit.Colors.InkSoft, Size = UDim2.new(1, 0, 0, 22),
	})
	h.LayoutOrder = 4

	local order = 4
	local function paletteRow(p, premium)
		order = order + 1
		local active = state.cottagePaint == p.id
		local locked = premium and not (state.passes and state.passes.deluxe_home)
		local r, b = row(holder, order, premium and "⭐" or "🎨", p.label,
			locked and "Needs the Deluxe Cottage pass." or (active and "Your current color." or ""),
			locked and "Locked" or (active and "Painted" or "Paint"),
			active and UIKit.Colors.Gold or UIKit.Colors.Night,
			(locked or active) and nil or function()
				remotes.events.PaintCottage:FireServer(p.id)
			end, locked or active)
		-- color swatch
		local swatch = UIKit.frame({
			Parent = r, Color = p.wall, CornerRadius = 6,
			Size = UDim2.fromOffset(22, 22), Position = UDim2.fromOffset(30, 21),
		})
		UIKit.stroke(swatch, p.trim, 3)
	end
	for _, p in ipairs(Config.PaintPalettes) do paletteRow(p, false) end
	for _, p in ipairs(Monetization.PremiumPalettes) do paletteRow(p, true) end
end

local function buildHouse(gui)
	local overlay, content = UIKit.panel(gui, "HousePanel", "🏠 My Cottage", UDim2.fromOffset(470, 460))
	panels.house = { overlay = overlay, rebuild = function() rebuildHouse(content) end }
end

-- HELP -----------------------------------------------------------------------------------

local function buildHelp(gui)
	local overlay, content = UIKit.panel(gui, "HelpPanel", "🌊 Welcome to Lanternside Bay", UDim2.fromOffset(470, 420))
	local holder = UIKit.scroll({ Parent = content, Name = "Rows" })
	UIKit.list(holder, 10)
	local sections = {
		{ "🎣 Fish", "Cast a line at any marked spot on the pier or boardwalk. When the ❗ appears — reel! Sell your basket at the Fish Market. Rarer fish bite at night." },
		{ "💼 Work", "Take a job from the notice board: Barista, Baker, or Courier. Follow the glowing props; every task pays coins." },
		{ "🏠 Live", "Hold a cottage's porch sign to claim it, then repaint it from the House menu and lock your door." },
		{ "⛴️ Ride", "The Pelican ferry loops the bay from the end of the pier. Hop on a bench and enjoy the view." },
		{ "🕯️ Evenings", "At dusk the lamps come on and the lighthouse wakes up. Campfire's in the park. Rare eels are in the water." },
		{ "💬 Chat", "Chat bubbles show over your head. Emotes and titles are in the Style menu." },
	}
	for i, s in ipairs(sections) do
		local r = UIKit.frame({
			Parent = holder, Color = UIKit.Colors.CreamDark, CornerRadius = 10,
			Size = UDim2.new(1, -8, 0, 66),
		})
		r.LayoutOrder = i
		UIKit.label({
			Parent = r, Text = s[1], Font = Enum.Font.GothamBold, TextSize = 15,
			Size = UDim2.new(1, -20, 0, 24), Position = UDim2.fromOffset(10, 4),
		})
		UIKit.label({
			Parent = r, Text = s[2], TextSize = 13, TextColor = UIKit.Colors.InkSoft,
			Size = UDim2.new(1, -20, 0, 36), Position = UDim2.fromOffset(10, 26),
			YAlign = Enum.TextYAlignment.Top,
		})
	end
	panels.help = { overlay = overlay, rebuild = function() end }
end

-- PUBLIC ------------------------------------------------------------------------------------

function Panels.build(gui, remoteMap, stateGetter)
	remotes = remoteMap
	getState = stateGetter
	buildShop(gui)
	buildJobs(gui)
	buildStyle(gui)
	buildHouse(gui)
	buildHelp(gui)
end

function Panels.toggle(name)
	local p = panels[name]
	if not p then return end
	-- close the others
	for otherName, other in pairs(panels) do
		if otherName ~= name then
			other.overlay.Visible = false
		end
	end
	if p.overlay.Visible then
		p.overlay.Visible = false
	else
		p.rebuild()
		p.overlay.Visible = true
	end
end

function Panels.open(name)
	local p = panels[name]
	if not p then return end
	for otherName, other in pairs(panels) do
		if otherName ~= name then
			other.overlay.Visible = false
		end
	end
	p.rebuild()
	p.overlay.Visible = true
end

function Panels.refreshOpen()
	for _, p in pairs(panels) do
		if p.overlay.Visible then
			p.rebuild()
		end
	end
end

return Panels
</ProtectedString>
</Properties>

</Item>
<Item class="ModuleScript" referent="RBX0022">
<Properties>
<string name="Name">UIKit</string>
<ProtectedString name="Source">--[[
	Lanternside Bay — UIKit (client)
	Small helpers for building the whole interface in code, with one shared
	"sea glass &amp; driftwood" look: cream panels, teal accents, soft corners.
]]

local UIKit = {}

UIKit.Colors = {
	Cream = Color3.fromRGB(248, 244, 236),
	CreamDark = Color3.fromRGB(236, 229, 216),
	Ink = Color3.fromRGB(45, 52, 60),
	InkSoft = Color3.fromRGB(96, 104, 112),
	Teal = Color3.fromRGB(44, 140, 142),
	TealDark = Color3.fromRGB(32, 106, 108),
	Gold = Color3.fromRGB(214, 172, 60),
	Danger = Color3.fromRGB(198, 92, 80),
	Night = Color3.fromRGB(52, 62, 82),
}

function UIKit.corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = parent
	return c
end

function UIKit.stroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(210, 200, 185)
	s.Thickness = thickness or 1.5
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

function UIKit.padding(parent, all)
	local p = Instance.new("UIPadding")
	local u = UDim.new(0, all or 10)
	p.PaddingTop = u
	p.PaddingBottom = u
	p.PaddingLeft = u
	p.PaddingRight = u
	p.Parent = parent
	return p
end

function UIKit.frame(props)
	local f = Instance.new("Frame")
	f.Name = props.Name or "Frame"
	f.Size = props.Size or UDim2.fromOffset(200, 100)
	f.Position = props.Position or UDim2.new(0, 0, 0, 0)
	f.AnchorPoint = props.AnchorPoint or Vector2.new(0, 0)
	f.BackgroundColor3 = props.Color or UIKit.Colors.Cream
	f.BackgroundTransparency = props.Transparency or 0
	f.BorderSizePixel = 0
	f.Visible = (props.Visible ~= false)
	f.ZIndex = props.ZIndex or 1
	f.Parent = props.Parent
	if props.Corner ~= false then UIKit.corner(f, props.CornerRadius) end
	return f
end

function UIKit.label(props)
	local l = Instance.new("TextLabel")
	l.Name = props.Name or "Label"
	l.Size = props.Size or UDim2.fromScale(1, 1)
	l.Position = props.Position or UDim2.new(0, 0, 0, 0)
	l.AnchorPoint = props.AnchorPoint or Vector2.new(0, 0)
	l.BackgroundTransparency = 1
	l.Font = props.Font or Enum.Font.Gotham
	l.Text = props.Text or ""
	l.TextColor3 = props.TextColor or UIKit.Colors.Ink
	l.TextSize = props.TextSize or 16
	l.TextScaled = props.TextScaled or false
	l.TextWrapped = (props.TextWrapped ~= false)
	l.TextXAlignment = props.XAlign or Enum.TextXAlignment.Left
	l.TextYAlignment = props.YAlign or Enum.TextYAlignment.Center
	l.RichText = (props.RichText == true)
	l.ZIndex = props.ZIndex or 1
	l.Parent = props.Parent
	return l
end

function UIKit.button(props)
	local b = Instance.new("TextButton")
	b.Name = props.Name or "Button"
	b.Size = props.Size or UDim2.fromOffset(120, 36)
	b.Position = props.Position or UDim2.new(0, 0, 0, 0)
	b.AnchorPoint = props.AnchorPoint or Vector2.new(0, 0)
	b.BackgroundColor3 = props.Color or UIKit.Colors.Teal
	b.AutoButtonColor = true
	b.Font = props.Font or Enum.Font.GothamBold
	b.Text = props.Text or "Button"
	b.TextColor3 = props.TextColor or Color3.fromRGB(255, 255, 255)
	b.TextSize = props.TextSize or 16
	b.TextScaled = props.TextScaled or false
	b.BorderSizePixel = 0
	b.ZIndex = props.ZIndex or 1
	b.Parent = props.Parent
	UIKit.corner(b, props.CornerRadius)
	if props.OnClick then
		b.Activated:Connect(props.OnClick)
	end
	return b
end

function UIKit.list(parent, padding, direction)
	local l = Instance.new("UIListLayout")
	l.Padding = UDim.new(0, padding or 8)
	l.FillDirection = direction or Enum.FillDirection.Vertical
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Parent = parent
	return l
end

function UIKit.scroll(props)
	local s = Instance.new("ScrollingFrame")
	s.Name = props.Name or "Scroll"
	s.Size = props.Size or UDim2.fromScale(1, 1)
	s.Position = props.Position or UDim2.new(0, 0, 0, 0)
	s.BackgroundTransparency = 1
	s.BorderSizePixel = 0
	s.ScrollBarThickness = 6
	s.ScrollBarImageColor3 = UIKit.Colors.InkSoft
	s.AutomaticCanvasSize = Enum.AutomaticSize.Y
	s.CanvasSize = UDim2.new(0, 0, 0, 0)
	s.ZIndex = props.ZIndex or 1
	s.Parent = props.Parent
	return s
end

-- A standard closable panel window, centered. Returns the content frame.
function UIKit.panel(gui, name, title, size)
	local overlay = UIKit.frame({
		Name = name, Parent = gui, Corner = false,
		Size = UDim2.fromScale(1, 1), Transparency = 0.45,
		Color = Color3.fromRGB(20, 26, 34), Visible = false, ZIndex = 5,
	})
	local win = UIKit.frame({
		Name = "Window", Parent = overlay,
		Size = size or UDim2.fromOffset(460, 420),
		Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5),
		Color = UIKit.Colors.Cream, ZIndex = 6, CornerRadius = 14,
	})
	UIKit.stroke(win, Color3.fromRGB(215, 205, 188), 2)
	UIKit.label({
		Parent = win, Text = title, Font = Enum.Font.GothamBold,
		Size = UDim2.new(1, -60, 0, 46), Position = UDim2.fromOffset(18, 4),
		TextSize = 20, ZIndex = 7,
	})
	UIKit.button({
		Parent = win, Text = "✕", Color = UIKit.Colors.Danger,
		Size = UDim2.fromOffset(34, 34), Position = UDim2.new(1, -42, 0, 8),
		ZIndex = 7, CornerRadius = 8,
		OnClick = function()
			overlay.Visible = false
		end,
	})
	local content = UIKit.frame({
		Name = "Content", Parent = win, Corner = false, Transparency = 1,
		Size = UDim2.new(1, -24, 1, -64), Position = UDim2.fromOffset(12, 52), ZIndex = 6,
	})
	return overlay, content
end

return UIKit
</ProtectedString>
</Properties>

</Item>
</Item>
</Item>
